    "debian-gnome-live": {
      "name": "Debian 13 GNOME Live",
      "meta": {
        "slug": "debian",
        "family": "debian",
        "role": "desktop",
        "release_model": "stable"
      },
      "iso": "isos/debian-live-13.4.0-amd64-gnome.iso",
      "iso_url": "https://cdimage.debian.org/debian-cd/current-live/amd64/iso-hybrid/debian-live-13.4.0-amd64-gnome.iso",
      "disk": {
        "path": "artifacts/debian-gnome-live/disk.qcow2",
        "size": "28G",
        "format": "qcow2",
        "interface": "virtio"
      },
      "firmware": {
        "type": "efi",
        "code": "/usr/share/OVMF/OVMF_CODE_4M.fd",
        "vars_template": "/usr/share/OVMF/OVMF_VARS_4M.fd",
        "vars_path": "artifacts/debian-gnome-live/OVMF_VARS.fd"
      },
      "machine": "q35",
      "memory_mb": 3072,
      "cpus": 2,
      "network": "user",
      "audio": true,
      "video": {
        "default": "std",
        "variants": {
          "std": [
            "-vga",
            "std",
            "-display",
            "gtk"
          ],
          "safe": [
            "-vga",
            "std",
            "-display",
            "gtk",
            "-serial",
            "mon:stdio"
          ]
        }
      },
      "usb_tablet": true
    },
