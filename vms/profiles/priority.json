{
  "vms": {
    "linuxmint-cinnamon": {
      "name": "Linux Mint 22.3 Cinnamon",
      "meta": {
        "catalog_slug": "linux-mint",
        "family": "mint",
        "role": "desktop",
        "release_model": "stable"
      },
      "iso": "isos/linuxmint-22.3-cinnamon-64bit.iso",
      "iso_url": "https://mirrors.edge.kernel.org/linuxmint/stable/22.3/linuxmint-22.3-cinnamon-64bit.iso",
      "disk": {
        "path": "artifacts/linuxmint-cinnamon/disk.qcow2",
        "size": "32G",
        "format": "qcow2",
        "interface": "virtio"
      },
      "firmware": {
        "type": "efi",
        "code": "/usr/share/OVMF/OVMF_CODE_4M.fd",
        "vars_template": "/usr/share/OVMF/OVMF_VARS_4M.fd",
        "vars_path": "artifacts/linuxmint-cinnamon/OVMF_VARS.fd"
      },
      "machine": "q35",
      "memory_mb": 4096,
      "cpus": 4,
      "network": "user",
      "audio": true,
      "video": {
        "default": "std",
        "variants": {
          "std": [
            "-vga",
            "std",
            "-display",
            "gtk"
          ],
          "safe": [
            "-vga",
            "std",
            "-display",
            "gtk",
            "-serial",
            "mon:stdio"
          ]
        }
      },
      "usb_tablet": true
    },
