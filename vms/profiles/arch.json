    "arch-noctalia-local": {
      "name": "Arch Linux + Noctalia 5",
      "meta": {
        "slug": "archlinux",
        "family": "arch",
        "role": "desktop",
        "release_model": "rolling"
      },
      "iso": "isos/archlinux-2026.04.01-x86_64.iso",
      "iso_url": "https://mirrors.dotsrc.org/archlinux/iso/latest/archlinux-2026.04.01-x86_64.iso",
      "disk": {
        "path": "artifacts/arch-noctalia-local/disk.qcow2",
        "size": "32G",
        "format": "qcow2",
        "interface": "virtio"
      },
      "firmware": {
        "type": "efi",
        "code": "/usr/share/OVMF/OVMF_CODE_4M.fd",
        "vars_template": "/usr/share/OVMF/OVMF_VARS_4M.fd",
        "vars_path": "artifacts/arch-noctalia-local/OVMF_VARS.fd"
      },
      "machine": "q35",
      "memory_mb": 8192,
      "cpus": 4,
      "network": "user",
      "audio": true,
      "video": {
        "default": "virtio-gl",
        "variants": {
          "std": ["-vga", "std", "-display", "gtk"],
          "safe": ["-vga", "std", "-display", "gtk"],
          "virtio-gl": ["-device", "virtio-vga-gl", "-display", "gtk,gl=on"]
        }
      },
      "usb_tablet": true,
      "archinstall_config": {
        "hostname": "arch-noctalia-local",
        "username": "manzolo",
        "password": "manzolo",
        "timezone": "Europe/Rome",
        "keyboard_layout": "it",
        "locale_lang": "it_IT",
        "locale_enc": "UTF-8",
        "bootloader": "Grub",
        "kernels": ["linux"],
        "audio": true,
        "packages": [
          "adwaita-icon-theme",
          "brightnessctl",
          "bash-completion",
          "bat",
          "btop",
          "cliphist",
          "curl",
          "eza",
          "fastfetch",
          "ffmpeg",
          "fd",
          "foot",
          "fuzzel",
          "gnome-keyring",
          "grim",
          "greetd",
          "gvfs",
          "gvfs-mtp",
          "gvfs-smb",
          "imagemagick",
          "inetutils",
          "jq",
          "jemalloc",
          "cli11",
          "cmake",
          "less",
          "niri",
          "libxkbcommon",
          "man-db",
          "man-pages",
          "mesa",
          "nano",
          "ninja",
          "noto-fonts-cjk",
          "noto-fonts",
          "noto-fonts-emoji",
          "nautilus",
          "papirus-icon-theme",
          "pavucontrol",
          "pipewire",
          "pipewire-pulse",
          "playerctl",
          "polkit",
          "power-profiles-daemon",
          "python",
          "qt6-base",
          "qt6-declarative",
          "qt6-multimedia",
          "qt6-shadertools",
          "qt6-svg",
          "qt6-wayland",
          "ripgrep",
          "rsync",
          "seatd",
          "seahorse",
          "slurp",
          "swappy",
          "tree",
          "ttf-dejavu",
          "ttf-jetbrains-mono-nerd",
          "udisks2",
          "udiskie",
          "unrar",
          "unzip",
          "upower",
          "vim",
          "vulkan-headers",
          "wayland-protocols",
          "wget",
          "wireplumber",
          "wl-clipboard",
          "wlr-randr",
          "xdg-desktop-portal",
          "xdg-desktop-portal-gnome",
          "xdg-desktop-portal-gtk",
          "xdg-user-dirs",
          "xdg-utils",
          "xwayland-satellite",
          "xorg-xwayland",
          "zip",
          "p7zip"
        ],
        "bootstrap_chroot_commands": [
          "pacman -S --noconfirm --needed git base-devel",
          "usermod -aG seat manzolo",
          "systemctl enable seatd greetd",
          "cat > /etc/greetd/config.toml <<\"EOF\"\n[terminal]\nvt = 1\n\n[initial_session]\ncommand = \"niri-session\"\nuser = \"manzolo\"\n\n[default_session]\ncommand = \"agreety\"\nuser = \"greeter\"\nEOF"
        ]
      },
      "ssh_provision": {
        "hostname": "arch-noctalia-local",
        "user": "manzolo",
        "ssh_host_port": 2226,
        "copy_from_host": [
          {
            "source": "vms/profile-files/arch-noctalia-local/bin/start-noctalia",
            "dest": "/home/manzolo/bin/start-noctalia",
            "dest_mode": "755"
          },
          {
            "source": "vms/profile-files/arch-noctalia-local/bin/arch-noctalia-post-install",
            "dest": "/home/manzolo/bin/arch-noctalia-post-install",
            "dest_mode": "755"
          },
          {
            "source": "vms/profile-files/arch-noctalia-local/niri/config.kdl",
            "dest": "/home/manzolo/.config/niri/config.kdl",
            "dest_mode": "644"
          }
        ],
        "post_install_run": [
          "~/bin/arch-noctalia-post-install",
          "command -v noctalia >/dev/null && noctalia --version || true",
          "command -v niri >/dev/null && niri --version || true"
        ]
      }
    }
  }
}
