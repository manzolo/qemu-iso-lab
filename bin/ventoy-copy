#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  sudo bin/ventoy-copy <target> <file.vhd>

  <target> can be:
    - a block partition (e.g. /dev/sdb1): it gets mounted under /mnt/ventoy-copy-$$
    - an already-mounted mountpoint (e.g. /run/media/user/Ventoy)

Examples:
  sudo bin/ventoy-copy /dev/sdb1 artifacts/cachyos/disk.vhd
  sudo bin/ventoy-copy /run/media/user/Ventoy artifacts/cachyos/disk.vhd

Notes:
  - The file is copied with the .vtoy suffix required by Ventoy
  - Before copying, prepare the disk with: sudo bin/ventoy-prep
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Missing command: $1" >&2
    exit 1
  }
}

cleanup() {
  if [[ "${MOUNTED_BY_SCRIPT:-0}" == "1" ]] && mountpoint -q "${TARGET_DIR}" 2>/dev/null; then
    umount "${TARGET_DIR}"
    rmdir "${TARGET_DIR}" 2>/dev/null || true
  fi
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

TARGET="${1:-}"
SRC_PATH="${2:-}"

if [[ -z "${TARGET}" || -z "${SRC_PATH}" ]]; then
  usage >&2
  exit 1
fi

if [[ "${EUID}" -ne 0 ]]; then
  echo "Run as root: sudo $0 ..." >&2
  exit 1
fi

require_cmd cp
require_cmd sync
require_cmd mountpoint
require_cmd findmnt

if [[ ! -f "${SRC_PATH}" ]]; then
  echo "Source file not found: ${SRC_PATH}" >&2
  exit 1
fi

DEST_NAME="$(basename "${SRC_PATH}").vtoy"

MOUNTED_BY_SCRIPT=0
TARGET_DIR=""
trap cleanup EXIT

if [[ -b "${TARGET}" ]]; then
  require_cmd mount
  require_cmd umount
  TARGET_DIR="/mnt/ventoy-copy-$$"
  mkdir -p "${TARGET_DIR}"
  mount "${TARGET}" "${TARGET_DIR}"
  MOUNTED_BY_SCRIPT=1
elif [[ -d "${TARGET}" ]]; then
  TARGET_DIR="${TARGET}"
  if ! mountpoint -q "${TARGET_DIR}"; then
    echo "The directory exists but does not appear mounted: ${TARGET_DIR}" >&2
    exit 1
  fi
else
  echo "Invalid target: ${TARGET}" >&2
  exit 1
fi

FSTYPE="$(findmnt -n -o FSTYPE --target "${TARGET_DIR}" || true)"
echo "Destination: ${TARGET_DIR} (${FSTYPE:-unknown fs})"
echo "Copying: ${SRC_PATH}"
echo "Into:    ${TARGET_DIR}/${DEST_NAME}"

cp -f "${SRC_PATH}" "${TARGET_DIR}/${DEST_NAME}"
sync

echo
echo "Copy complete:"
echo "  ${TARGET_DIR}/${DEST_NAME}"
