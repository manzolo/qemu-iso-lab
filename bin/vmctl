#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import selectors
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path


ROOT = Path(__file__).resolve().parent.parent
CONFIG_PATH = ROOT / "vms.json"
HTTP_USER_AGENT = "Mozilla/5.0 (compatible; vmctl/1.0; +https://local.repo)"
REQUIRED_COMMANDS = ["qemu-system-x86_64", "qemu-img", "python3"]
OPTIONAL_COMMANDS = {"dialog": "required only for the TUI"}
COMMON_OVMF_PAIRS = [
    ("/usr/share/OVMF/OVMF_CODE_4M.fd", "/usr/share/OVMF/OVMF_VARS_4M.fd"),
    ("/usr/share/OVMF/OVMF_CODE.fd", "/usr/share/OVMF/OVMF_VARS.fd"),
    ("/usr/share/edk2/x64/OVMF_CODE.4m.fd", "/usr/share/edk2/x64/OVMF_VARS.4m.fd"),
    ("/usr/share/edk2/x64/OVMF_CODE.fd", "/usr/share/edk2/x64/OVMF_VARS.fd"),
    ("/usr/share/edk2-ovmf/x64/OVMF_CODE.4m.fd", "/usr/share/edk2-ovmf/x64/OVMF_VARS.4m.fd"),
    ("/usr/share/edk2-ovmf/x64/OVMF_CODE.fd", "/usr/share/edk2-ovmf/x64/OVMF_VARS.fd"),
]
USE_COLOR = (
    os.environ.get("NO_COLOR") != "1"
    and os.environ.get("TERM", "") not in ("", "dumb")
    and getattr(sys.stdout, "isatty", lambda: False)() is True
)
RESET = "\033[0m" if USE_COLOR else ""
BOLD = "\033[1m" if USE_COLOR else ""
BLUE = "\033[34m" if USE_COLOR else ""
CYAN = "\033[36m" if USE_COLOR else ""
GREEN = "\033[32m" if USE_COLOR else ""
YELLOW = "\033[33m" if USE_COLOR else ""
RED = "\033[31m" if USE_COLOR else ""


class VMError(Exception):
    pass


def style(text: str, *codes: str) -> str:
    if not USE_COLOR:
        return text
    return "".join(codes) + text + RESET


def print_header(title: str) -> None:
    print(f"{style('==>', BOLD, BLUE)} {style(title, BOLD)}")


def print_kv(label: str, value: str) -> None:
    print(f"  {style(f'{label:<10}', CYAN)} {value}")


def print_status(marker: str, text: str, ok: bool = True) -> None:
    color = GREEN if ok else YELLOW
    print(f"  [{style(marker, color, BOLD)}] {text}")


def print_command(cmd: list[str]) -> None:
    print(f"{style('$', BOLD, BLUE)} {' '.join(cmd)}")


def print_note(text: str) -> None:
    print(f"{style('::', BOLD, CYAN)} {text}")


def load_config() -> dict:
    with CONFIG_PATH.open("r", encoding="utf-8") as fh:
        data = json.load(fh)
    if "vms" not in data or not isinstance(data["vms"], dict):
        raise VMError(f"Invalid config file: {CONFIG_PATH}")
    return data


def get_vm(config: dict, name: str) -> dict:
    try:
        return config["vms"][name]
    except KeyError as exc:
        raise VMError(f"VM profile not found: {name}") from exc


def resolve_path(path_str: str) -> Path:
    path = Path(path_str)
    return path if path.is_absolute() else ROOT / path


def require_command(name: str) -> None:
    if shutil.which(name) is None:
        raise VMError(f"Missing command: {name}")


def run(cmd: list[str], dry_run: bool = False) -> None:
    print_command(cmd)
    if not dry_run:
        subprocess.run(cmd, check=True)


def ensure_parent(path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)


def looks_like_html(path: Path) -> bool:
    try:
        with path.open("rb") as fh:
            prefix = fh.read(512).lstrip().lower()
    except OSError:
        return False
    return prefix.startswith(b"<!doctype html") or prefix.startswith(b"<html")


def download_file(url: str, destination: Path, dry_run: bool = False) -> None:
    print_note(f"Downloading {url} -> {destination}")
    ensure_parent(destination)
    if dry_run:
        return

    try:
        request = urllib.request.Request(url, headers={"User-Agent": HTTP_USER_AGENT})
        with urllib.request.urlopen(request) as response, destination.open("wb") as fh:
            content_type = response.headers.get("Content-Type", "")
            if "text/html" in content_type.lower():
                raise VMError(f"Refusing HTML response for ISO download: {url}")
            shutil.copyfileobj(response, fh)
    except VMError:
        if destination.exists():
            destination.unlink()
        raise
    except (OSError, urllib.error.URLError) as exc:
        if destination.exists():
            destination.unlink()
        raise VMError(f"Failed to download '{url}': {exc}") from exc

    if looks_like_html(destination):
        destination.unlink()
        raise VMError(f"Downloaded HTML instead of ISO from '{url}'")


def ensure_iso(vm: dict, dry_run: bool = False) -> Path:
    iso_path = resolve_path(vm["iso"])
    if iso_path.is_file():
        if looks_like_html(iso_path):
            print_status("warn", f"Removing invalid cached ISO placeholder: {iso_path}", ok=False)
            if not dry_run:
                iso_path.unlink()
            else:
                return iso_path
        else:
            print_status("ok", f"ISO already exists: {iso_path}")
            return iso_path
    if iso_path.exists():
        raise VMError(f"ISO path exists but is not a regular file: {iso_path}")

    iso_url = vm.get("iso_url")
    if not iso_url:
        raise VMError(f"ISO not found and no iso_url configured: {iso_path}")

    download_file(iso_url, iso_path, dry_run=dry_run)
    return iso_path


def ensure_vm_dirs(name: str) -> Path:
    base = ROOT / "artifacts" / name
    (base / "logs").mkdir(parents=True, exist_ok=True)
    (base / "runtime").mkdir(parents=True, exist_ok=True)
    return base


def read_os_release() -> dict[str, str]:
    os_release = Path("/etc/os-release")
    if not os_release.is_file():
        return {}

    data: dict[str, str] = {}
    for line in os_release.read_text(encoding="utf-8").splitlines():
        if "=" not in line or line.startswith("#"):
            continue
        key, value = line.split("=", 1)
        data[key] = value.strip().strip('"')
    return data


def host_install_hints() -> list[str]:
    os_release = read_os_release()
    distro_tokens = {
        token
        for key in ("ID", "ID_LIKE")
        for token in os_release.get(key, "").replace(",", " ").split()
        if token
    }

    if {"arch", "cachyos", "manjaro"} & distro_tokens:
        return ["sudo pacman -S qemu-desktop qemu-base edk2-ovmf python dialog make"]
    if {"debian", "ubuntu"} & distro_tokens:
        return [
            "sudo apt update",
            "sudo apt install -y qemu-system-x86 qemu-utils ovmf python3 make dialog",
        ]
    return [
        "Install QEMU, Python 3, make, and OVMF/edk2 firmware with your distro package manager.",
        "Optional: install dialog if you want to use make tui.",
    ]


def iter_ovmf_candidates(fw: dict) -> list[tuple[Path, Path]]:
    candidates: list[tuple[Path, Path]] = []

    env_code = os.environ.get("OVMF_CODE")
    env_vars = os.environ.get("OVMF_VARS_TEMPLATE")
    if env_code and env_vars:
        candidates.append((Path(env_code), Path(env_vars)))

    configured_code = fw.get("code")
    configured_vars = fw.get("vars_template")
    if configured_code and configured_vars:
        candidates.append((resolve_path(configured_code), resolve_path(configured_vars)))

    for code, vars_template in COMMON_OVMF_PAIRS:
        candidates.append((Path(code), Path(vars_template)))

    unique: list[tuple[Path, Path]] = []
    seen: set[tuple[str, str]] = set()
    for code, vars_template in candidates:
        key = (str(code), str(vars_template))
        if key not in seen:
            unique.append((code, vars_template))
            seen.add(key)
    return unique


def resolve_efi_firmware(fw: dict) -> tuple[Path, Path, Path]:
    vars_path = resolve_path(fw["vars_path"])
    for code, vars_template in iter_ovmf_candidates(fw):
        if code.is_file() and vars_template.is_file():
            return code, vars_template, vars_path

    configured_code = resolve_path(fw["code"]) if fw.get("code") else None
    configured_vars = resolve_path(fw["vars_template"]) if fw.get("vars_template") else None
    lines = ["Unable to locate OVMF firmware files for EFI guest."]
    if configured_code:
        lines.append(f"Configured code path: {configured_code}")
    if configured_vars:
        lines.append(f"Configured vars template path: {configured_vars}")
    if "OVMF_CODE" in os.environ or "OVMF_VARS_TEMPLATE" in os.environ:
        lines.append("Environment overrides detected: OVMF_CODE / OVMF_VARS_TEMPLATE")
    lines.append("Run 'make setup' to inspect host dependencies and suggested packages.")
    raise VMError(" ".join(lines))


def firmware_status(vm: dict) -> tuple[str, str]:
    fw = vm["firmware"]
    fw_type = fw["type"]
    if fw_type == "bios":
        return fw_type, "SeaBIOS / no OVMF required"
    if fw_type != "efi":
        raise VMError(f"Unsupported firmware type: {fw_type}")

    code, vars_template, vars_path = resolve_efi_firmware(fw)
    return fw_type, f"code={code} vars_template={vars_template} vars_path={vars_path}"


def machine_arg(vm: dict, accel: str | None = None) -> str:
    machine = vm["machine"]
    if accel:
        return f"{machine},accel={accel}"
    return machine


def firmware_args(vm: dict, dry_run: bool = False) -> list[str]:
    fw = vm["firmware"]
    fw_type = fw["type"]
    if fw_type == "bios":
        return []
    if fw_type != "efi":
        raise VMError(f"Unsupported firmware type: {fw_type}")

    code, vars_template, vars_path = resolve_efi_firmware(fw)
    if not vars_path.exists():
        ensure_parent(vars_path)
        print_note(f"Creating EFI vars store: {vars_path}")
        if not dry_run:
            shutil.copyfile(vars_template, vars_path)

    return [
        "-drive",
        f"if=pflash,format=raw,readonly=on,file={code}",
        "-drive",
        f"if=pflash,format=raw,file={vars_path}",
    ]


def disk_args(vm: dict) -> list[str]:
    disk = vm["disk"]
    disk_path = resolve_path(disk["path"])
    if not disk_path.exists():
        raise VMError(f"Disk image not found: {disk_path}")
    interface = disk.get("interface", "virtio")
    return [
        "-drive",
        f"file={disk_path},format={disk['format']},if={interface}",
    ]


def video_args(vm: dict, variant: str | None) -> list[str]:
    video = vm.get("video", {})
    variants = video.get("variants", {})
    selected = variant or video.get("default")
    if not selected:
        return []
    if selected not in variants:
        choices = ", ".join(sorted(variants))
        raise VMError(f"Unknown video profile '{selected}'. Choices: {choices}")
    return list(variants[selected])


def common_args(
    vm: dict,
    variant: str | None,
    dry_run: bool = False,
    accel: str | None = "kvm",
    headless: bool = False,
    serial_stdio: bool = False,
    no_reboot: bool = False,
) -> list[str]:
    require_command("qemu-system-x86_64")
    cpu_model = "host" if accel == "kvm" else vm.get("cpu_model", "max")
    args = [
        "qemu-system-x86_64",
        "-m",
        str(vm["memory_mb"]),
        "-cpu",
        cpu_model,
        "-smp",
        str(vm["cpus"]),
        "-machine",
        machine_arg(vm, accel=accel),
        "-boot",
        "menu=on",
    ]
    if accel == "kvm":
        args.insert(1, "-enable-kvm")
    args += firmware_args(vm, dry_run=dry_run)
    args += disk_args(vm)

    if headless:
        args += ["-display", "none", "-monitor", "none"]
    else:
        args += video_args(vm, variant)

    if serial_stdio:
        args += ["-chardev", "stdio,id=char0,signal=off", "-serial", "chardev:char0"]

    if vm.get("usb_tablet"):
        args += ["-usb", "-device", "qemu-xhci", "-device", "usb-tablet"]

    if vm.get("audio"):
        args += ["-device", "ich9-intel-hda", "-device", "hda-duplex"]

    network_mode = vm.get("network", "user")
    if network_mode == "user":
        args += ["-netdev", "user,id=n1", "-device", "virtio-net-pci,netdev=n1"]
    else:
        raise VMError(f"Unsupported network mode: {network_mode}")

    if no_reboot:
        args += ["-no-reboot"]

    return args


def run_and_expect(
    cmd: list[str],
    expected_text: str,
    timeout_sec: int,
    auto_inputs: list[tuple[str, str]] | None = None,
    dry_run: bool = False,
) -> None:
    print_command(cmd)
    if dry_run:
        return

    deadline = time.monotonic() + timeout_sec
    process = subprocess.Popen(
        cmd,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
    )
    captured: list[str] = []
    sent_inputs: set[tuple[str, str]] = set()
    selector = selectors.DefaultSelector()
    selector.register(process.stdout, selectors.EVENT_READ)

    try:
        while True:
            remaining = deadline - time.monotonic()
            if remaining <= 0:
                raise VMError(
                    f"Timed out after {timeout_sec}s waiting for '{expected_text}'. "
                    f"Captured output:\n{''.join(captured)[-4000:]}"
                )

            events = selector.select(timeout=min(0.2, remaining))
            if events:
                chunk = os.read(process.stdout.fileno(), 4096).decode(errors="replace")
                if chunk:
                    sys.stdout.write(chunk)
                    sys.stdout.flush()
                    captured.append(chunk)
                    full_output = "".join(captured)
                    if auto_inputs:
                        for match_text, send_text in auto_inputs:
                            key = (match_text, send_text)
                            if key in sent_inputs:
                                continue
                            if match_text in full_output:
                                process.stdin.write(send_text.encode())
                                process.stdin.flush()
                                sent_inputs.add(key)
                    if expected_text in full_output:
                        process.terminate()
                        try:
                            process.wait(timeout=10)
                        except subprocess.TimeoutExpired:
                            process.kill()
                            process.wait(timeout=10)
                        return
                continue

            if process.poll() is not None:
                remaining_output = process.stdout.read()
                if remaining_output:
                    chunk = remaining_output.decode(errors="replace")
                    sys.stdout.write(chunk)
                    sys.stdout.flush()
                    captured.append(chunk)
                    if expected_text in "".join(captured):
                        return
                raise VMError(
                    f"QEMU exited before emitting '{expected_text}'. "
                    f"Captured output:\n{''.join(captured)[-4000:]}"
                )

            time.sleep(min(0.2, remaining))
    finally:
        selector.close()
        if process.poll() is None:
            process.kill()
            process.wait(timeout=10)


def cmd_list(args: argparse.Namespace) -> int:
    config = load_config()
    rows = []
    for name, vm in sorted(config["vms"].items()):
        firmware = vm.get("firmware", {}).get("type", "?").upper()
        memory = vm.get("memory_mb", "?")
        cpus = vm.get("cpus", "?")
        rows.append((name, vm.get("name", name), firmware, str(memory), str(cpus)))

    name_width = max(len("PROFILE"), max(len(row[0]) for row in rows))
    label_width = max(len("NAME"), max(len(row[1]) for row in rows))
    firmware_width = max(len("FW"), max(len(row[2]) for row in rows))
    memory_width = max(len("RAM"), max(len(f"{row[3]}M") for row in rows))
    cpu_width = max(len("CPU"), max(len(row[4]) for row in rows))
    print(f"{style('PROFILE', BOLD, CYAN):<{name_width + len(BOLD) + len(CYAN) + len(RESET)}}  "
          f"{style('NAME', BOLD, CYAN):<{label_width + len(BOLD) + len(CYAN) + len(RESET)}}  "
          f"{style('FW', BOLD, CYAN):>{firmware_width + len(BOLD) + len(CYAN) + len(RESET)}}  "
          f"{style('RAM', BOLD, CYAN):>{memory_width + len(BOLD) + len(CYAN) + len(RESET)}}  "
          f"{style('CPU', BOLD, CYAN):>{cpu_width + len(BOLD) + len(CYAN) + len(RESET)}}")
    for name, label, firmware, memory, cpus in rows:
        print(f"{style(name, BOLD):<{name_width + len(BOLD) + len(RESET)}}  "
              f"{label:<{label_width}}  "
              f"{firmware:>{firmware_width}}  "
              f"{f'{memory}M':>{memory_width}}  "
              f"{cpus:>{cpu_width}}")
    return 0


def cmd_show(args: argparse.Namespace) -> int:
    config = load_config()
    vm = get_vm(config, args.vm)
    print_header(f"VM profile: {args.vm}")
    print(json.dumps(vm, indent=2))
    return 0


def cmd_fetch_iso(args: argparse.Namespace) -> int:
    config = load_config()
    vm = get_vm(config, args.vm)
    ensure_iso(vm, dry_run=args.dry_run)
    return 0


def cmd_prep(args: argparse.Namespace) -> int:
    config = load_config()
    vm = get_vm(config, args.vm)
    ensure_vm_dirs(args.vm)

    require_command("qemu-img")
    disk = vm["disk"]
    disk_path = resolve_path(disk["path"])
    ensure_iso(vm, dry_run=args.dry_run)

    if not disk_path.exists():
        ensure_parent(disk_path)
        cmd = ["qemu-img", "create", "-f", disk["format"]]
        if disk.get("subformat"):
            cmd += ["-o", f"subformat={disk['subformat']}"]
        cmd += [str(disk_path), disk["size"]]
        run(cmd, dry_run=args.dry_run)
    else:
        print_status("ok", f"Disk already exists: {disk_path}")

    firmware_args(vm, dry_run=args.dry_run)
    print_status("ok", f"Prepared VM '{args.vm}'")
    return 0


def cmd_install(args: argparse.Namespace) -> int:
    config = load_config()
    vm = get_vm(config, args.vm)
    ensure_vm_dirs(args.vm)
    iso_path = ensure_iso(vm, dry_run=args.dry_run)
    qemu_args = common_args(vm, args.video, dry_run=args.dry_run)
    qemu_args += ["-cdrom", str(iso_path)]
    run(qemu_args, dry_run=args.dry_run)
    return 0


def cmd_start(args: argparse.Namespace) -> int:
    config = load_config()
    vm = get_vm(config, args.vm)
    ensure_vm_dirs(args.vm)
    qemu_args = common_args(vm, args.video, dry_run=args.dry_run)
    run(qemu_args, dry_run=args.dry_run)
    return 0


def cmd_boot_check(args: argparse.Namespace) -> int:
    config = load_config()
    vm = get_vm(config, args.vm)
    ensure_vm_dirs(args.vm)

    ci = vm.get("ci", {})
    expected_text = args.expect or ci.get("expect")
    if not expected_text:
        raise VMError(f"Missing boot expectation for VM '{args.vm}'")

    timeout_sec = args.timeout or ci.get("timeout_sec", 90)
    accel = ci.get("accel", "tcg")
    headless = ci.get("headless", True)
    boot_from = ci.get("boot_from", "cdrom")
    auto_inputs = [(item["match"], item["send"]) for item in ci.get("auto_input", [])]

    qemu_args = common_args(
        vm,
        variant=None,
        dry_run=args.dry_run,
        accel=accel,
        headless=headless,
        serial_stdio=True,
        no_reboot=True,
    )

    if boot_from == "cdrom":
        iso_path = ensure_iso(vm, dry_run=args.dry_run)
        qemu_args += ["-boot", "once=d", "-cdrom", str(iso_path)]
    elif boot_from != "disk":
        raise VMError(f"Unsupported boot_from mode: {boot_from}")

    run_and_expect(
        qemu_args,
        expected_text,
        int(timeout_sec),
        auto_inputs=auto_inputs,
        dry_run=args.dry_run,
    )
    print_status("ok", f"Boot check passed for '{args.vm}'")
    return 0


def cmd_setup(args: argparse.Namespace) -> int:
    config = load_config()
    status_ok = True

    print_header("Host dependency check")
    for name in REQUIRED_COMMANDS:
        present = shutil.which(name) is not None
        marker = "ok" if present else "missing"
        print_status(marker, name, ok=present)
        status_ok = status_ok and present

    print_header("Optional tools")
    for name, note in OPTIONAL_COMMANDS.items():
        present = shutil.which(name) is not None
        marker = "ok" if present else "missing"
        print_status(marker, f"{name} ({note})", ok=present)

    print_header("Firmware check")
    efi_vms = [(name, vm) for name, vm in sorted(config["vms"].items()) if vm["firmware"]["type"] == "efi"]
    if not efi_vms:
        print_status("ok", "No EFI profiles configured")
    else:
        for name, vm in efi_vms:
            try:
                _, details = firmware_status(vm)
                print_status("ok", f"{name}: {details}")
            except VMError as exc:
                print_status("missing", f"{name}: {exc}", ok=False)
                status_ok = False

    if status_ok:
        print_status("ok", "Setup check passed.")
        return 0

    print_header("Suggested install commands")
    for cmd in host_install_hints():
        print_kv("cmd", cmd)
    return 1


def clean_vm(name: str, vm: dict, dry_run: bool = False) -> None:
    disk_path = resolve_path(vm["disk"]["path"])
    fw = vm["firmware"]
    vars_path = resolve_path(fw["vars_path"]) if fw["type"] == "efi" else None
    for path in [disk_path, vars_path]:
        if path and path.exists():
            print_note(f"Removing {path}")
            if not dry_run:
                path.unlink()
    base = ROOT / "artifacts" / name
    for subdir in [base / "runtime", base / "logs"]:
        if subdir.exists() and not any(subdir.iterdir()):
            print_note(f"Removing empty dir {subdir}")
            if not dry_run:
                subdir.rmdir()
    if base.exists() and not any(base.iterdir()):
        print_note(f"Removing empty dir {base}")
        if not dry_run:
            base.rmdir()


def cmd_clean(args: argparse.Namespace) -> int:
    config = load_config()
    if args.all:
        for name, vm in sorted(config["vms"].items()):
            clean_vm(name, vm, dry_run=args.dry_run)
        return 0
    vm = get_vm(config, args.vm)
    clean_vm(args.vm, vm, dry_run=args.dry_run)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="vmctl")
    parser.add_argument("--dry-run", action="store_true", help="print commands without executing them")
    subparsers = parser.add_subparsers(dest="command", required=True)

    p = subparsers.add_parser("list")
    p.set_defaults(func=cmd_list)

    p = subparsers.add_parser("show")
    p.add_argument("vm")
    p.set_defaults(func=cmd_show)

    p = subparsers.add_parser("fetch-iso")
    p.add_argument("vm")
    p.set_defaults(func=cmd_fetch_iso)

    p = subparsers.add_parser("prep")
    p.add_argument("vm")
    p.set_defaults(func=cmd_prep)

    p = subparsers.add_parser("install")
    p.add_argument("vm")
    p.add_argument("--video")
    p.set_defaults(func=cmd_install)

    p = subparsers.add_parser("start")
    p.add_argument("vm")
    p.add_argument("--video")
    p.set_defaults(func=cmd_start)

    p = subparsers.add_parser("boot-check")
    p.add_argument("vm")
    p.add_argument("--expect")
    p.add_argument("--timeout", type=int)
    p.set_defaults(func=cmd_boot_check)

    p = subparsers.add_parser("setup")
    p.set_defaults(func=cmd_setup)

    p = subparsers.add_parser("clean")
    p.add_argument("vm", nargs="?")
    p.add_argument("--all", action="store_true")
    p.set_defaults(func=cmd_clean)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()

    if args.command == "clean" and not args.all and not args.vm:
        parser.error("clean requires a VM name or --all")

    try:
        return args.func(args)
    except VMError as exc:
        print(style(f"error: {exc}", RED, BOLD), file=sys.stderr)
        return 1
    except subprocess.CalledProcessError as exc:
        print(style(f"error: command failed with exit code {exc.returncode}", RED, BOLD), file=sys.stderr)
        return exc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
