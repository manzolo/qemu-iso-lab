#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="${VMTUI_ROOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
CONFIG_DIR="${VMTUI_CONFIG_DIR:-$ROOT_DIR/vms}"
VMCTL="$ROOT_DIR/bin/vmctl"

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'error: missing command: %s\n' "$1" >&2
        exit 1
    fi
}

require_command dialog
require_command python3

if [[ ! -x "$VMCTL" ]]; then
    printf 'error: missing executable: %s\n' "$VMCTL" >&2
    exit 1
fi

if [[ ! -d "$CONFIG_DIR" ]]; then
    printf 'error: missing config directory: %s\n' "$CONFIG_DIR" >&2
    exit 1
fi

current_vm=""

menu_choose() {
    local title="$1"
    local prompt="$2"
    shift 2
    local output
    local status
    local height="${MENU_HEIGHT:-22}"
    local width="${MENU_WIDTH:-80}"
    local list_height="${MENU_LIST_HEIGHT:-12}"

    output=$(dialog --clear --stdout --title "$title" --menu "$prompt" "$height" "$width" "$list_height" "$@") || status=$?
    status=${status:-0}
    if [[ $status -ne 0 ]]; then
        return 1
    fi
    printf '%s\n' "$output"
}

msg_box() {
    dialog --clear --title "$1" --msgbox "$2" 10 72
}

confirm_box() {
    dialog --clear --title "$1" --yesno "$2" 10 72
}

input_box() {
    local title="$1"
    local prompt="$2"
    local initial="${3:-}"
    local output
    local status

    output=$(dialog --clear --stdout --title "$title" --inputbox "$prompt" 12 72 "$initial") || status=$?
    status=${status:-0}
    if [[ $status -ne 0 ]]; then
        return 1
    fi
    printf '%s\n' "$output"
}

pause_box() {
    read -r -p "Press Enter to continue..." _
}

install_command_for() {
    case "$1" in
        remote-viewer)
            if command -v apt-get >/dev/null 2>&1; then
                printf '%s\n' "sudo apt-get install -y virt-viewer"
            elif command -v pacman >/dev/null 2>&1; then
                printf '%s\n' "sudo pacman -S --needed virt-viewer"
            elif command -v dnf >/dev/null 2>&1; then
                printf '%s\n' "sudo dnf install -y virt-viewer"
            else
                return 1
            fi
            ;;
        *)
            return 1
            ;;
    esac
}

ensure_optional_command() {
    local command_name="$1"
    local install_cmd

    if command -v "$command_name" >/dev/null 2>&1; then
        return 0
    fi

    install_cmd=$(install_command_for "$command_name") || {
        msg_box "Missing Command" "Missing command: $command_name\n\nInstall it manually and retry."
        return 1
    }

    if ! confirm_box "Install Dependency" "Missing command: $command_name\n\nInstall it now?\n\n$install_cmd"; then
        return 1
    fi

    clear
    printf '$ %s\n\n' "$install_cmd"
    if bash -lc "$install_cmd"; then
        printf '\nDependency installed.\n'
    else
        printf '\nDependency installation failed.\n'
        pause_box
        return 1
    fi
    pause_box

    command -v "$command_name" >/dev/null 2>&1
}

list_vm_menu_items() {
    python3 - "$CONFIG_DIR" <<'PY'
import json
import sys
from pathlib import Path


def ellipsize(text: str, width: int) -> str:
    if len(text) <= width:
        return text
    if width <= 3:
        return text[:width]
    return text[: width - 3] + "..."


config_dir = Path(sys.argv[1])
data = {"catalog": {}, "vms": {}}
for profile_path in sorted((config_dir / "profiles").glob("*.json")):
    profile_data = json.loads(profile_path.read_text(encoding="utf-8"))
    data["vms"].update(profile_data["vms"])
for name, vm in sorted(data["vms"].items()):
    label = vm.get("name", name)
    firmware = str(vm.get("firmware", {}).get("type", "?")).upper()
    memory = f"{vm.get('memory_mb', '?')} MB"
    cpus = vm.get("cpus", "?")
    cpu_label = f"{cpus} vCPU" if cpus == 1 else f"{cpus} vCPUs"
    description = "  ".join(
        [
            f"{ellipsize(label, 28):<28}",
            f"{firmware:>4}",
            f"{memory:>7}",
            f"{cpu_label:>7}",
        ]
    )
    print(name)
    print(description)
PY
}

list_video_menu_items() {
    python3 - "$CONFIG_DIR" "$1" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
vm_name = sys.argv[2]
data = {"vms": {}}
for profile_path in sorted((config_dir / "profiles").glob("*.json")):
    profile_data = json.loads(profile_path.read_text(encoding="utf-8"))
    data["vms"].update(profile_data["vms"])
vm = data["vms"][vm_name]
video = vm.get("video", {})
default = video.get("default", "")
variants = video.get("variants", {})
print("Default")
print(f"VM profile default ({default or 'none'})")
for name in sorted(variants):
    print(name)
    print(f"{name} video profile")
PY
}

vm_has_section() {
    python3 - "$CONFIG_DIR" "$1" "$2" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
vm_name = sys.argv[2]
section = sys.argv[3]
data = {"vms": {}}
for profile_path in sorted((config_dir / "profiles").glob("*.json")):
    profile_data = json.loads(profile_path.read_text(encoding="utf-8"))
    data["vms"].update(profile_data["vms"])
vm = data["vms"][vm_name]
raise SystemExit(0 if isinstance(vm.get(section), dict) else 1)
PY
}

vm_has_ssh_provision() {
    python3 - "$CONFIG_DIR" "$1" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
vm_name = sys.argv[2]
data = {"vms": {}}
for profile_path in sorted((config_dir / "profiles").glob("*.json")):
    profile_data = json.loads(profile_path.read_text(encoding="utf-8"))
    data["vms"].update(profile_data["vms"])
vm = data["vms"][vm_name]
ssh_cfg = vm.get("ssh_provision")
cloud_cfg = vm.get("cloud_init")
raise SystemExit(0 if isinstance(ssh_cfg, dict) or isinstance(cloud_cfg, dict) else 1)
PY
}

list_remote_menu_items() {
    python3 - "$CONFIG_DIR" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
path = config_dir / "remotes.json"
if not path.exists():
    raise SystemExit(0)
data = json.loads(path.read_text(encoding="utf-8"))
remotes = data.get("remotes", {})
if not isinstance(remotes, dict):
    raise SystemExit(0)
for name, remote in sorted(remotes.items()):
    if not isinstance(remote, dict):
        continue
    label = remote.get("label", name)
    target = remote.get("ssh_target", "")
    project = remote.get("project_dir", "")
    ports = f"{remote.get('local_spice_port', 5930)}->{remote.get('remote_spice_port', 5930)}"
    print(name)
    print(f"{label}  {target}  {ports}  {project}")
PY
}

remote_field() {
    python3 - "$CONFIG_DIR" "$1" "$2" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
remote_name = sys.argv[2]
field = sys.argv[3]
path = config_dir / "remotes.json"
data = json.loads(path.read_text(encoding="utf-8"))
remote = data.get("remotes", {}).get(remote_name)
if not isinstance(remote, dict):
    raise SystemExit(f"unknown remote: {remote_name}")
value = remote.get(field, "")
print(value)
PY
}

list_vm_action_items() {
    local vm_name="$1"
    printf '%s\n' "Start Here" "Recommended flows for this VM"
    printf '%s\n' "Installation" "ISO, disk preparation, and installers"
    printf '%s\n' "Run & Access" "Boot, stop, shell, and first boot tasks"
    printf '%s\n' "Maintenance" "Boot checks and artifact cleanup"
    printf '%s\n' "Profile Details" "Review this VM configuration"
    printf '%s\n' "Main Menu" "Return to the main menu"
}

list_quick_action_items() {
    local vm_name="$1"
    if vm_has_section "$vm_name" "autoinstall" && vm_has_section "$vm_name" "cloud_init"; then
        printf '%s\n' "Full Bootstrap" "Unattended install, first boot, and post-install"
    fi
    if vm_has_section "$vm_name" "cloud_init"; then
        printf '%s\n' "Cloud-Init Flow" "Manual installer with first-boot handoff"
    else
        printf '%s\n' "Guided Install" "Fetch ISO, prepare artifacts, boot installer"
    fi
    printf '%s\n' "Boot Desktop" "Start the installed VM with display"
    printf '%s\n' "Boot Headless" "Start the installed VM in the background"
    if vm_has_ssh_provision "$vm_name"; then
        printf '%s\n' "SSH Console" "Open a shell inside the VM"
    fi
    printf '%s\n' "Back" "Return to VM actions"
}

list_install_action_items() {
    local vm_name="$1"
    printf '%s\n' "Fetch ISO" "Download or validate the configured ISO"
    printf '%s\n' "Prepare VM" "Create disk and firmware artifacts"
    printf '%s\n' "Guided Provision" "Fetch ISO, prepare artifacts, boot installer"
    printf '%s\n' "Installer Only" "Boot the installer without preparation"
    if vm_has_section "$vm_name" "autoinstall"; then
        printf '%s\n' "Autoinstall" "Run the unattended Ubuntu installer"
    fi
    if vm_has_section "$vm_name" "cloud_init"; then
        printf '%s\n' "Cloud-Init Flow" "Manual install with generated first-boot data"
        printf '%s\n' "Seeded Installer" "Boot installer with a generated cloud-init seed"
    fi
    printf '%s\n' "Back" "Return to VM actions"
}

list_run_action_items() {
    local vm_name="$1"
    printf '%s\n' "Boot Desktop" "Start the installed VM with display"
    printf '%s\n' "Boot Headless" "Start the installed VM in the background"
    printf '%s\n' "Remote SPICE" "Start this VM on a remote host and open a SPICE viewer"
    printf '%s\n' "Stop VM" "Stop the tracked background process"
    if vm_has_ssh_provision "$vm_name"; then
        printf '%s\n' "SSH Console" "Open a shell inside the VM"
        printf '%s\n' "Post-Install" "Run configured SSH provisioning tasks"
    fi
    if vm_has_section "$vm_name" "cloud_init"; then
        printf '%s\n' "First Boot" "Start the VM with cloud-init enabled"
    fi
    printf '%s\n' "Back" "Return to VM actions"
}

list_maintenance_action_items() {
    printf '%s\n' "Boot Check" "Run a headless smoke test"
    printf '%s\n' "Clean VM" "Remove artifacts for this VM"
    printf '%s\n' "Delete ISO" "Remove this VM's cached ISO"
    printf '%s\n' "Back" "Return to VM actions"
}

list_empty_device_menu_items() {
    python3 - "$VMCTL" <<'PY'
import subprocess
import sys

vmctl = sys.argv[1]
result = subprocess.run(
    [vmctl, "list-empty-devices"],
    check=True,
    capture_output=True,
    text=True,
)
for line in result.stdout.splitlines():
    if not line.strip():
        continue
    path, size, model = (line.split("\t", 2) + ["-", "-"])[:3]
    print(path)
    print(f"{size:>10}  {model}")
PY
}

list_target_device_menu_items() {
    python3 - "$VMCTL" <<'PY'
import subprocess
import sys

vmctl = sys.argv[1]
result = subprocess.run(
    [vmctl, "list-target-devices"],
    check=True,
    capture_output=True,
    text=True,
)
for line in result.stdout.splitlines():
    if not line.strip():
        continue
    path, size, model = (line.split("\t", 2) + ["-", "-"])[:3]
    print(path)
    print(f"{size:>10}  {model}")
PY
}

run_vmctl() {
    clear
    printf 'Selected VM: %s\n' "$current_vm"
    printf '$ %q' "$VMCTL"
    for arg in "$@"; do
        printf ' %q' "$arg"
    done
    printf '\n\n'

    if "$VMCTL" "$@"; then
        printf '\nCommand completed successfully.\n'
    else
        local status=$?
        printf '\nCommand failed with exit code %s.\n' "$status"
    fi
    pause_box
}

remote_spice_session() {
    require_command ssh
    ensure_optional_command remote-viewer || return 0

    local remote_name
    local remote_target
    local remote_dir
    local local_port
    local remote_port
    local quoted_dir
    local quoted_vm
    local remote_cmd
    local tunnel_pid

    mapfile -t remote_items < <(list_remote_menu_items)
    if [[ ${#remote_items[@]} -eq 0 ]]; then
        msg_box "No Remotes" "Create vms/remotes.json first.\n\nUse vms/remotes.json.example as a template."
        return 0
    fi

    remote_name=$(MENU_WIDTH=110 MENU_LIST_HEIGHT=10 menu_choose "Remote SPICE" "Choose a remote host" "${remote_items[@]}") || return 0
    remote_target=$(remote_field "$remote_name" "ssh_target")
    remote_dir=$(remote_field "$remote_name" "project_dir")
    local_port=$(remote_field "$remote_name" "local_spice_port")
    remote_port=$(remote_field "$remote_name" "remote_spice_port")

    if [[ ! "$local_port" =~ ^[0-9]+$ || ! "$remote_port" =~ ^[0-9]+$ ]]; then
        msg_box "Invalid Port" "SPICE ports must be numeric."
        return 0
    fi

    printf -v quoted_dir '%q' "$remote_dir"
    printf -v quoted_vm '%q' "$current_vm"
    remote_cmd="cd $quoted_dir && ./bin/vmctl start $quoted_vm --spice-port $remote_port --background"

    clear
    printf 'Remote VM: %s\n' "$current_vm"
    printf 'Remote host: %s\n' "$remote_target"
    printf 'Remote project: %s\n' "$remote_dir"
    printf 'SPICE tunnel: 127.0.0.1:%s -> %s:127.0.0.1:%s\n\n' "$local_port" "$remote_target" "$remote_port"

    printf '$ ssh -N -L %q %q &\n' "$local_port:127.0.0.1:$remote_port" "$remote_target"
    ssh -N -L "$local_port:127.0.0.1:$remote_port" "$remote_target" &
    tunnel_pid=$!
    sleep 1

    printf '$ ssh %q %q\n\n' "$remote_target" "$remote_cmd"
    if ! ssh "$remote_target" "$remote_cmd"; then
        kill "$tunnel_pid" >/dev/null 2>&1 || true
        wait "$tunnel_pid" >/dev/null 2>&1 || true
        pause_box
        return 0
    fi

    printf '\n$ remote-viewer %q\n\n' "spice://127.0.0.1:$local_port"
    remote-viewer "spice://127.0.0.1:$local_port" || true
    kill "$tunnel_pid" >/dev/null 2>&1 || true
    wait "$tunnel_pid" >/dev/null 2>&1 || true
    pause_box
}

choose_vm() {
    mapfile -t vm_items < <(list_vm_menu_items)
    local selected
    selected=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=14 menu_choose "VM Selection" "Choose a VM profile" "${vm_items[@]}") || return 1
    current_vm="$selected"
    return 0
}

choose_video() {
    mapfile -t video_items < <(list_video_menu_items "$current_vm")
    local selected
    selected=$(menu_choose "Video Profile" "Choose a video profile for $current_vm" "${video_items[@]}") || return 1
    if [[ "$selected" == "Default" || "$selected" == "__default__" ]]; then
        printf '\n'
    else
        printf '%s\n' "$selected"
    fi
}

resolve_action() {
    case "$1" in
        "Start Here") printf '%s\n' quick-actions ;;
        "Installation") printf '%s\n' install-flows ;;
        "Run & Access") printf '%s\n' run-flows ;;
        "Maintenance") printf '%s\n' maintenance-flows ;;
        "Profile Details") printf '%s\n' show ;;
        "Main Menu"|"Back") printf '%s\n' back ;;
        "Full Bootstrap") printf '%s\n' bootstrap-unattended ;;
        "Guided Install"|"Guided Provision") printf '%s\n' provision ;;
        "Boot Desktop") printf '%s\n' start ;;
        "Boot Headless") printf '%s\n' start-headless ;;
        "Remote SPICE") printf '%s\n' remote-spice ;;
        "SSH Console") printf '%s\n' shell ;;
        "Fetch ISO") printf '%s\n' fetch-iso ;;
        "Prepare VM") printf '%s\n' prep ;;
        "Installer Only") printf '%s\n' install ;;
        "Autoinstall") printf '%s\n' full-auto-install ;;
        "Cloud-Init Flow") printf '%s\n' cloud-init-install ;;
        "Seeded Installer") printf '%s\n' install-cloud-init ;;
        "Stop VM") printf '%s\n' stop ;;
        "Post-Install") printf '%s\n' post-install ;;
        "First Boot") printf '%s\n' start-cloud-init ;;
        "Boot Check") printf '%s\n' boot-check ;;
        "Clean VM") printf '%s\n' clean ;;
        "Delete ISO") printf '%s\n' delete-iso ;;
        "Choose VM") printf '%s\n' choose-vm ;;
        "Status") printf '%s\n' status ;;
        "Advanced") printf '%s\n' advanced ;;
        "Clean All") printf '%s\n' clean-all ;;
        "Quit") printf '%s\n' quit ;;
        "Flash Empty Disk") printf '%s\n' flash ;;
        "Force Flash") printf '%s\n' flash-force ;;
        "Import Disk") printf '%s\n' import-device ;;
        *) printf '%s\n' "$1" ;;
    esac
}

run_action() {
    local action
    action=$(resolve_action "$1")
    case "$action" in
        show)
            run_vmctl show "$current_vm"
            ;;
        provision)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Confirm Provision" "Guided install for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- start the installer"; then
                if [[ -n "$video" ]]; then
                    run_vmctl provision "$current_vm" --video "$video"
                else
                    run_vmctl provision "$current_vm"
                fi
            fi
            ;;
        cloud-init-install)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Manual Install With Cloud-Init" "Start the guided manual install flow for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- boot the installer now\n\nAfter the OS install finishes, come back and run:\n- Boot installed VM with cloud-init first boot\n- Run SSH post-install actions"; then
                if [[ -n "$video" ]]; then
                    run_vmctl provision "$current_vm" --video "$video"
                else
                    run_vmctl provision "$current_vm"
                fi
                msg_box "Next Steps" "After completing the OS installation inside the VM:\n\n1. Return to this menu\n2. Run 'Boot installed VM with cloud-init first boot'\n3. Then run 'Run SSH post-install actions'\n\nFor ubuntu-niri-local this is the intended flow."
            fi
            ;;
        full-auto-install)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Fully Automatic Install" "Run the fully automatic Ubuntu autoinstall flow for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- boot the installer in autoinstall mode\n- exit when the installer reboots after finishing\n\nAfter that, start the installed VM normally and then run SSH post-install actions."; then
                if [[ -n "$video" ]]; then
                    run_vmctl install-unattended "$current_vm" --video "$video"
                else
                    run_vmctl install-unattended "$current_vm"
                fi
                msg_box "Next Steps" "When the unattended installer exits on reboot:\n\n1. Run 'Boot installed VM'\n2. Wait for the guest to finish its first boot\n3. Run 'Run SSH post-install actions'\n\nNo manual installer interaction is expected in this flow."
            fi
            ;;
        bootstrap-unattended)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Bootstrap Unattended" "Run the fully unattended bootstrap flow for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- run Ubuntu autoinstall\n- start the installed VM headless in the background\n- wait for SSH and run post-install actions\n\nUse this only when autoinstall and cloud-init are both configured correctly."; then
                if [[ -n "$video" ]]; then
                    run_vmctl bootstrap-unattended "$current_vm" --video "$video"
                else
                    run_vmctl bootstrap-unattended "$current_vm"
                fi
            fi
            ;;
        fetch-iso)
            run_vmctl fetch-iso "$current_vm"
            ;;
        prep)
            run_vmctl prep "$current_vm"
            ;;
        install)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl install "$current_vm" --video "$video"
            else
                run_vmctl install "$current_vm"
            fi
            ;;
        install-cloud-init)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl install "$current_vm" --video "$video" --cloud-init
            else
                run_vmctl install "$current_vm" --cloud-init
            fi
            ;;
        start)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl start "$current_vm" --video "$video"
            else
                run_vmctl start "$current_vm"
            fi
            ;;
        start-headless)
            run_vmctl start "$current_vm" --headless --background
            ;;
        remote-spice)
            remote_spice_session
            ;;
        stop)
            if confirm_box "Confirm Stop" "Stop the tracked background VM for '$current_vm' if it is running?"; then
                run_vmctl stop "$current_vm"
            fi
            ;;
        shell)
            run_vmctl shell "$current_vm"
            ;;
        start-cloud-init)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl start "$current_vm" --video "$video" --cloud-init
            else
                run_vmctl start "$current_vm" --cloud-init
            fi
            ;;
        post-install)
            run_vmctl post-install "$current_vm"
            ;;
        boot-check)
            run_vmctl boot-check "$current_vm"
            ;;
        clean)
            if confirm_box "Confirm Clean" "Remove artifacts for VM '$current_vm'?"; then
                run_vmctl clean "$current_vm"
            fi
            ;;
        flash)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_empty_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Empty Devices" "No empty whole-disk devices are currently eligible for flashing, or elevated privileges are required to inspect them."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Flash Device" "Choose an empty target disk" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Operation" "Write VM '$current_vm' to physical device '$selected_device'?\n\nThis will overwrite the entire disk."; then
                return 0
            fi
            typed_device=$(input_box "Type Device Path" "Type the device path again to confirm destructive flash:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Flash cancelled."
                return 0
            fi
            run_vmctl flash "$current_vm" --device "$selected_device" --confirm-device "$typed_device"
            ;;
        flash-force)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_target_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Eligible Devices" "No non-root whole-disk devices are currently available for force flashing."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Force Flash Device" "Choose a target disk to wipe and overwrite" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Force Flash" "Force-write VM '$current_vm' to '$selected_device'?\n\nThis will wipe existing partition tables and signatures before writing."; then
                return 0
            fi
            typed_device=$(input_box "Type WIPE Device" "Type the device path again to confirm forced destructive flash:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Force flash cancelled."
                return 0
            fi
            run_vmctl flash "$current_vm" --device "$selected_device" --confirm-device "$typed_device" --force-target
            ;;
        import-device)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_target_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Eligible Devices" "No non-root whole-disk devices are currently available for import."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Import Device" "Choose a physical disk to read into the VM image" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Import" "Import physical device '$selected_device' into VM '$current_vm'?\n\nThis will overwrite the VM disk image."; then
                return 0
            fi
            typed_device=$(input_box "Type Source Device" "Type the device path again to confirm VM disk overwrite:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Import cancelled."
                return 0
            fi
            run_vmctl import-device "$current_vm" --device "$selected_device" --confirm-device "$typed_device"
            ;;
        clean-all)
            if confirm_box "Confirm Clean All" "Remove artifacts for all configured VMs?"; then
                run_vmctl clean --all
            fi
            ;;
        delete-iso)
            if confirm_box "Confirm Delete ISO" "Delete the cached ISO for VM '$current_vm'?\n\nThis only removes the ISO file configured in the VM profile. It does not remove VM disks or generated artifacts."; then
                run_vmctl delete-iso "$current_vm"
            fi
            ;;
        quick-actions)
            quick_menu_loop
            ;;
        install-flows)
            install_menu_loop
            ;;
        run-flows)
            run_menu_loop
            ;;
        maintenance-flows)
            maintenance_menu_loop
            ;;
        status)
            run_vmctl status
            ;;
        advanced)
            advanced_menu_loop
            ;;
        back)
            return 1
            ;;
        choose-vm)
            choose_vm || return 1
            ;;
        quit)
            clear
            exit 0
            ;;
    esac
}

vm_menu_loop() {
    while true; do
        local -a menu_items=()
        mapfile -t menu_items < <(list_vm_action_items "$current_vm")
        local selected
        selected=$(menu_choose \
            "VM Actions" \
            "Current VM: $current_vm" \
            "${menu_items[@]}") || return 0
        run_action "$selected" || return 0
    done
}

quick_menu_loop() {
    while true; do
        local -a menu_items=()
        mapfile -t menu_items < <(list_quick_action_items "$current_vm")
        local selected
        selected=$(menu_choose \
            "Quick Actions" \
            "Current VM: $current_vm" \
            "${menu_items[@]}") || return 0
        run_action "$selected" || return 0
    done
}

install_menu_loop() {
    while true; do
        local -a menu_items=()
        mapfile -t menu_items < <(list_install_action_items "$current_vm")
        local selected
        selected=$(menu_choose \
            "Install Actions" \
            "Current VM: $current_vm" \
            "${menu_items[@]}") || return 0
        run_action "$selected" || return 0
    done
}

run_menu_loop() {
    while true; do
        local -a menu_items=()
        mapfile -t menu_items < <(list_run_action_items "$current_vm")
        local selected
        selected=$(menu_choose \
            "Run And Access" \
            "Current VM: $current_vm" \
            "${menu_items[@]}") || return 0
        run_action "$selected" || return 0
    done
}

maintenance_menu_loop() {
    while true; do
        local -a menu_items=()
        mapfile -t menu_items < <(list_maintenance_action_items)
        local selected
        selected=$(menu_choose \
            "Maintenance" \
            "Current VM: $current_vm" \
            "${menu_items[@]}") || return 0
        run_action "$selected" || return 0
    done
}

advanced_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "Advanced" \
            "Current VM: $current_vm" \
            "Flash Empty Disk" "Write the VM disk to an empty physical device" \
            "Force Flash" "Wipe and write a non-empty physical device" \
            "Import Disk" "Read a physical device into the VM image" \
            "Back" "Return to previous menu") || return 0
        run_action "$selected" || return 0
    done
}

main_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "QEMU ISO Lab" \
            "Choose where to work" \
            "Choose VM" "Select a VM profile and open its workspace" \
            "Status" "Show local VM state" \
            "Advanced" "Flash or import physical disks" \
            "Clean All" "Remove artifacts for all configured VMs" \
            "Quit" "Close the TUI") || {
                clear
                exit 0
            }

        case "$(resolve_action "$selected")" in
            choose-vm)
                if choose_vm; then
                    vm_menu_loop
                fi
                ;;
            advanced)
                if [[ -z "$current_vm" ]]; then
                    if choose_vm; then
                        advanced_menu_loop
                    fi
                else
                    advanced_menu_loop
                fi
                ;;
            status|clean-all|quit)
                run_action "$selected"
                ;;
        esac
    done
}

if [[ "${VMTUI_TEST_MODE:-0}" != "1" ]]; then
    main_menu_loop
fi
