    python3 - "$VMCTL" <<'PY'
import subprocess
import sys

vmctl = sys.argv[1]
result = subprocess.run(
    [vmctl, "list-target-devices"],
    check=True,
    capture_output=True,
    text=True,
)
for line in result.stdout.splitlines():
    if not line.strip():
        continue
    path, size, model = (line.split("\t", 2) + ["-", "-"])[:3]
    print(path)
    print(f"{size:>10}  {model}")
PY
}

run_vmctl() {
    clear
    printf 'Selected VM: %s\n' "$current_vm"
    printf '$ %q' "$VMCTL"
    for arg in "$@"; do
        printf ' %q' "$arg"
    done
    printf '\n\n'

    local status=0
    if "$VMCTL" "$@"; then
        printf '\nCommand completed successfully.\n'
    else
        status=$?
        printf '\nCommand failed with exit code %s.\n' "$status"
    fi
    pause_box
    return $status
}

remote_spice_session() {
    require_command ssh
    ensure_optional_command remote-viewer || return 0

    local remote_name
    local remote_target
    local remote_dir
    local local_port
    local remote_port
    local quoted_dir
    local quoted_vm
    local remote_cmd
    local tunnel_pid

    mapfile -t remote_items < <(list_remote_menu_items)
    if [[ ${#remote_items[@]} -eq 0 ]]; then
        msg_box "No Remotes" "Create vms/remotes.json first.\n\nUse vms/remotes.json.example as a template."
        return 0
    fi

    remote_name=$(MENU_WIDTH=110 MENU_LIST_HEIGHT=10 menu_choose "Remote SPICE" "Choose a remote host" "${remote_items[@]}") || return 0
    remote_target=$(remote_field "$remote_name" "ssh_target")
    remote_dir=$(remote_field "$remote_name" "project_dir")
    local_port=$(remote_field "$remote_name" "local_spice_port")
    remote_port=$(remote_field "$remote_name" "remote_spice_port")

    if [[ ! "$local_port" =~ ^[0-9]+$ || ! "$remote_port" =~ ^[0-9]+$ ]]; then
        msg_box "Invalid Port" "SPICE ports must be numeric."
        return 0
    fi

    printf -v quoted_dir '%q' "$remote_dir"
    printf -v quoted_vm '%q' "$current_vm"
    remote_cmd="cd $quoted_dir && ./bin/vmctl start $quoted_vm --spice-port $remote_port --background"

    clear
    printf 'Remote VM: %s\n' "$current_vm"
    printf 'Remote host: %s\n' "$remote_target"
    printf 'Remote project: %s\n' "$remote_dir"
    printf 'SPICE tunnel: 127.0.0.1:%s -> %s:127.0.0.1:%s\n\n' "$local_port" "$remote_target" "$remote_port"

    printf '$ ssh -N -L %q %q &\n' "$local_port:127.0.0.1:$remote_port" "$remote_target"
    ssh -N -L "$local_port:127.0.0.1:$remote_port" "$remote_target" &
    tunnel_pid=$!
    sleep 1

    printf '$ ssh %q %q\n\n' "$remote_target" "$remote_cmd"
    if ! ssh "$remote_target" "$remote_cmd"; then
        kill "$tunnel_pid" >/dev/null 2>&1 || true
        wait "$tunnel_pid" >/dev/null 2>&1 || true
        pause_box
        return 0
    fi

    printf '\n$ remote-viewer %q\n\n' "spice://127.0.0.1:$local_port"
    remote-viewer "spice://127.0.0.1:$local_port" || true
    kill "$tunnel_pid" >/dev/null 2>&1 || true
    wait "$tunnel_pid" >/dev/null 2>&1 || true
    pause_box
}

choose_video() {
    mapfile -t video_items < <(list_video_menu_items "$current_vm")
    local selected
    selected=$(menu_choose "Video Profile" "Choose a video profile for $current_vm" "${video_items[@]}") || return 1
    if [[ "$selected" == "Default" || "$selected" == "__default__" ]]; then
        printf '\n'
    else
        printf '%s\n' "$selected"
    fi
}

prompt_post_install() {
    local vm_name="$1"
    local installer_label="$2"
    local has_ssh=0
    vm_has_ssh_provision "$vm_name" && has_ssh=1

    local -a opts=()
    if [[ $has_ssh -eq 1 ]]; then
        opts+=("Start headless + SSH post-install" "Boot headless and run SSH provisioning")
    fi
    opts+=("Start with display" "Boot the installed VM with display")
    opts+=("Done" "Return to the VM menu")

    local choice
    choice=$(menu_choose "Install complete" \
        "${installer_label} finished for '$vm_name'. What next?" \
        "${opts[@]}") || return 0

    case "$choice" in
        "Start headless + SSH post-install")
            run_vmctl start "$vm_name" --headless --background || return 0
            if [[ $has_ssh -eq 1 ]]; then
                run_vmctl post-install "$vm_name" || true
            fi
            ;;
        "Start with display")
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl start "$vm_name" --video "$video" || true
            else
                run_vmctl start "$vm_name" || true
            fi
            ;;
        "Done")
            ;;
    esac
}

resolve_action() {
    case "$1" in
        "Profile Details") printf '%s\n' show ;;
        "Back") printf '%s\n' back ;;
        "Arch Bootstrap") printf '%s\n' bootstrap-archinstall ;;
        "Arch Install (Interactive)") printf '%s\n' install-archinstall ;;
        "Debian Preseed Bootstrap") printf '%s\n' bootstrap-preseed ;;
        "Kickstart Bootstrap") printf '%s\n' bootstrap-kickstart ;;
        "Full Bootstrap") printf '%s\n' bootstrap-unattended ;;
        "Guided Install"|"Guided Provision") printf '%s\n' provision ;;
        "Boot Desktop") printf '%s\n' start ;;
        "Boot Headless") printf '%s\n' start-headless ;;
        "Remote SPICE") printf '%s\n' remote-spice ;;
        "SSH Console") printf '%s\n' shell ;;
        "Fetch ISO") printf '%s\n' fetch-iso ;;
        "Prepare VM") printf '%s\n' prep ;;
        "Installer Only") printf '%s\n' install ;;
        "Unattended Install") printf '%s\n' full-auto-install ;;
        "Cloud-Init Flow") printf '%s\n' cloud-init-install ;;
        "Seeded Installer") printf '%s\n' install-cloud-init ;;
        "Stop VM") printf '%s\n' stop ;;
        "Post-Install") printf '%s\n' post-install ;;
        "First Boot") printf '%s\n' start-cloud-init ;;
        "Boot Check") printf '%s\n' boot-check ;;
        "Clean VM") printf '%s\n' clean ;;
        "Delete ISO") printf '%s\n' delete-iso ;;
        "Status") printf '%s\n' status ;;
        "Remote Hosts") printf '%s\n' remote-hosts ;;
        "Clean All") printf '%s\n' clean-all ;;
        "Quit") printf '%s\n' quit ;;
        "Flash Empty Disk") printf '%s\n' flash ;;
        "Force Flash") printf '%s\n' flash-force ;;
        "Import Disk") printf '%s\n' import-device ;;
        __sep_*) printf '%s\n' noop ;;
        *) printf '%s\n' "$1" ;;
    esac
}

run_action() {
    local action
    action=$(resolve_action "$1")
    case "$action" in
        noop)
            return 0
            ;;
        show)
            run_vmctl show "$current_vm" || true
            ;;
        provision)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Confirm Provision" "Guided install for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- start the installer"; then
                local ok=0
                if [[ -n "$video" ]]; then
                    run_vmctl provision "$current_vm" --video "$video" && ok=1
                else
                    run_vmctl provision "$current_vm" && ok=1
                fi
                if [[ $ok -eq 1 ]]; then
                    prompt_post_install "$current_vm" "Guided Provision"
                fi
            fi
            ;;
        cloud-init-install)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Cloud-Init Flow" "Start the guided manual install flow for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- boot the installer now\n\nWhen the OS install finishes you'll be offered the next step (boot + post-install)."; then
                local ok=0
                if [[ -n "$video" ]]; then
                    run_vmctl provision "$current_vm" --video "$video" && ok=1
                else
                    run_vmctl provision "$current_vm" && ok=1
                fi
                if [[ $ok -eq 1 ]]; then
                    prompt_post_install "$current_vm" "Cloud-Init Flow"
                fi
            fi
            ;;
        full-auto-install)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Unattended Install" "Run the configured Ubuntu autoinstall flow for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- boot the installer in unattended mode\n- exit when the installer reboots after finishing"; then
                local ok=0
                if [[ -n "$video" ]]; then
                    run_vmctl install-unattended "$current_vm" --video "$video" && ok=1
                else
                    run_vmctl install-unattended "$current_vm" && ok=1
                fi
                if [[ $ok -eq 1 ]]; then
                    prompt_post_install "$current_vm" "Unattended Install"
                fi
            fi
            ;;
        bootstrap-archinstall)
            if confirm_box "Arch Bootstrap" "Run the fully automated Arch Linux bootstrap for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts\n- boot the Arch live ISO headless via serial console\n- automatically trigger pacstrap, locale, user, GRUB\n- start the installed VM and run SSH post-install (paru + noctalia-git)\n\nExpected time: ~15-30 min depending on download speed."; then
                run_vmctl bootstrap-archinstall "$current_vm" || true
            fi
            ;;
        install-archinstall)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Arch Install (Interactive)" "Boot the Arch live ISO with a pre-built archinstall config disk for VM '$current_vm'?\n\nThis will:\n- generate archinstall-config.json + archinstall-creds.json\n- boot the live ISO with the config on /dev/vdb\n\nIn the live environment run:\n  mkdir -p /tmp/archconf\n  mount /dev/vdb /tmp/archconf\n  bash /tmp/archconf/run.sh"; then
                local ok=0
                if [[ -n "$video" ]]; then
                    run_vmctl install-archinstall "$current_vm" --video "$video" && ok=1
                else
                    run_vmctl install-archinstall "$current_vm" && ok=1
                fi
                if [[ $ok -eq 1 ]]; then
                    prompt_post_install "$current_vm" "Arch Install (Interactive)"
                fi
            fi
            ;;
        bootstrap-unattended)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Full Bootstrap" "Run the fully unattended Ubuntu bootstrap flow for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- run the configured Ubuntu autoinstall flow\n- start the installed VM headless in the background\n- wait for SSH and run post-install actions\n\nUse this only when autoinstall and SSH provisioning are configured correctly."; then
                if [[ -n "$video" ]]; then
                    run_vmctl bootstrap-unattended "$current_vm" --video "$video" || true
                else
                    run_vmctl bootstrap-unattended "$current_vm" || true
                fi
            fi
            ;;
        bootstrap-preseed)
            if confirm_box "Debian Preseed Bootstrap" "Run the fully automated Debian preseed bootstrap for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts\n- boot the Debian netinst headless via serial console\n- automatically run preseed install + late_command (SSH keys, sudoers)\n- start the installed VM and run SSH post-install\n\nExpected time: ~10-15 min depending on download speed."; then
                run_vmctl bootstrap-preseed "$current_vm" || true
            fi
            ;;
        bootstrap-kickstart)
            if confirm_box "Kickstart Bootstrap" "Run the fully automated AlmaLinux/RHEL kickstart bootstrap for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts\n- boot the AlmaLinux minimal ISO headless via serial console\n- automatically run kickstart install + %post (SSH keys, sudoers, SELinux)\n- start the installed VM and run SSH post-install\n\nExpected time: ~10 min depending on download speed."; then
                run_vmctl bootstrap-kickstart "$current_vm" || true
            fi
            ;;
        fetch-iso)
            run_vmctl fetch-iso "$current_vm" || true
            ;;
        prep)
            run_vmctl prep "$current_vm" || true
            ;;
        install)
            local video
            video=$(choose_video) || return 0
            local ok=0
            if [[ -n "$video" ]]; then
                run_vmctl install "$current_vm" --video "$video" && ok=1
            else
                run_vmctl install "$current_vm" && ok=1
            fi
            if [[ $ok -eq 1 ]]; then
                prompt_post_install "$current_vm" "Installer Only"
            fi
            ;;
        install-cloud-init)
            local video
            video=$(choose_video) || return 0
            local ok=0
            if [[ -n "$video" ]]; then
                run_vmctl install "$current_vm" --video "$video" --cloud-init && ok=1
            else
                run_vmctl install "$current_vm" --cloud-init && ok=1
            fi
            if [[ $ok -eq 1 ]]; then
                prompt_post_install "$current_vm" "Seeded Installer"
            fi
            ;;
        start)
            if vm_is_running_headless "$current_vm"; then
                local choice
                choice=$(menu_choose "VM Already Running" \
                    "VM '$current_vm' is already running headless.\nWhat do you want to do?" \
                    "Restart with Display" "Stop the headless VM and start it with display" \
                    "SSH Console"          "Open an SSH session inside the running VM" \
                    "Cancel"               "Return to the menu") || return 0
                case "$choice" in
                    "SSH Console")
                        run_vmctl shell "$current_vm" || true
                        ;;
                    "Restart with Display")
                        if confirm_box "Restart with Display" "Stop '$current_vm' and restart it with display?"; then
                            clear
                            printf 'Selected VM: %s\n\n' "$current_vm"
                            "$VMCTL" stop "$current_vm" || true
                            printf '\n'
                            local video
                            video=$(choose_video) || return 0
                            if [[ -n "$video" ]]; then
                                run_vmctl start "$current_vm" --video "$video" || true
                            else
                                run_vmctl start "$current_vm" || true
                            fi
                        fi
                        ;;
                esac
                return 0
            fi
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl start "$current_vm" --video "$video" || true
            else
                run_vmctl start "$current_vm" || true
            fi
            ;;
        start-headless)
            run_vmctl start "$current_vm" --headless --background || true
            ;;
        remote-spice)
            remote_spice_session
            ;;
        stop)
            if confirm_box "Confirm Stop" "Stop the tracked background VM for '$current_vm' if it is running?"; then
                run_vmctl stop "$current_vm" || true
            fi
            ;;
        shell)
            run_vmctl shell "$current_vm" || true
            ;;
        start-cloud-init)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl start "$current_vm" --video "$video" --cloud-init || true
            else
                run_vmctl start "$current_vm" --cloud-init || true
            fi
            ;;
        post-install)
            run_vmctl post-install "$current_vm" || true
            ;;
        boot-check)
            run_vmctl boot-check "$current_vm" || true
            ;;
        clean)
            if confirm_box "Confirm Clean" "Remove artifacts for VM '$current_vm'?"; then
                run_vmctl clean "$current_vm" || true
            fi
            ;;
        flash)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_empty_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Empty Devices" "No empty whole-disk devices are currently eligible for flashing, or elevated privileges are required to inspect them."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Flash Device" "Choose an empty target disk" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Operation" "Write VM '$current_vm' to physical device '$selected_device'?\n\nThis will overwrite the entire disk."; then
                return 0
            fi
            typed_device=$(input_box "Type Device Path" "Type the device path again to confirm destructive flash:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Flash cancelled."
                return 0
            fi
            run_vmctl flash "$current_vm" --device "$selected_device" --confirm-device "$typed_device" || true
            ;;
        flash-force)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_target_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Eligible Devices" "No non-root whole-disk devices are currently available for force flashing."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Force Flash Device" "Choose a target disk to wipe and overwrite" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Force Flash" "Force-write VM '$current_vm' to '$selected_device'?\n\nThis will wipe existing partition tables and signatures before writing."; then
                return 0
            fi
            typed_device=$(input_box "Type WIPE Device" "Type the device path again to confirm forced destructive flash:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Force flash cancelled."
                return 0
            fi
            run_vmctl flash "$current_vm" --device "$selected_device" --confirm-device "$typed_device" --force-target || true
            ;;
        import-device)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_target_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Eligible Devices" "No non-root whole-disk devices are currently available for import."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Import Device" "Choose a physical disk to read into the VM image" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Import" "Import physical device '$selected_device' into VM '$current_vm'?\n\nThis will overwrite the VM disk image."; then
                return 0
            fi
            typed_device=$(input_box "Type Source Device" "Type the device path again to confirm VM disk overwrite:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Import cancelled."
                return 0
            fi
            run_vmctl import-device "$current_vm" --device "$selected_device" --confirm-device "$typed_device" || true
            ;;
        clean-all)
            if confirm_box "Confirm Clean All" "Remove artifacts for all configured VMs?"; then
                run_vmctl clean --all || true
            fi
            ;;
        delete-iso)
            if confirm_box "Confirm Delete ISO" "Delete the cached ISO for VM '$current_vm'?\n\nThis only removes the ISO file configured in the VM profile. It does not remove VM disks or generated artifacts."; then
                run_vmctl delete-iso "$current_vm" || true
            fi
            ;;
        status)
            run_vmctl status || true
            ;;
        remote-hosts)
            remote_hosts_menu_loop
            ;;
        back)
            return 1
            ;;
        quit)
            clear
            exit 0
            ;;
    esac
}

vm_menu_loop() {
    while true; do
        local status_summary
        status_summary=$(vm_status_summary "$current_vm")
        local -a menu_items=()
        mapfile -t menu_items < <(list_vm_menu_items_unified "$current_vm")
        local selected
        selected=$(MENU_NO_TAGS=1 MENU_HEIGHT=28 MENU_WIDTH=86 MENU_LIST_HEIGHT=22 menu_choose \
            "$current_vm" \
            "Status: $status_summary" \
            "${menu_items[@]}") || return 0
        case "$selected" in
            __sep_*)
                continue
                ;;
            "Back")
                return 0
                ;;
        esac
        if is_na_action "$selected" "$current_vm"; then
            msg_na_action "$selected" "$current_vm"
            continue
        fi
        run_action "$selected" || return 0
    done
}

remote_hosts_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "Remote Hosts" \
            "Config: $CONFIG_DIR/remotes.json" \
            "Show Path" "Show local remotes config paths" \
            "Create Example" "Create vms/remotes.json from the example template" \
            "Edit Config" "Open vms/remotes.json with EDITOR" \
            "Back" "Return to main menu") || return 0
        case "$selected" in
            "Show Path")
                msg_box "Remote Hosts" "Config:\n$CONFIG_DIR/remotes.json\n\nTemplate:\n$CONFIG_DIR/remotes.json.example"
                ;;
            "Create Example")
                if [[ -e "$CONFIG_DIR/remotes.json" ]]; then
                    msg_box "Already Exists" "$CONFIG_DIR/remotes.json already exists."
                elif [[ ! -f "$CONFIG_DIR/remotes.json.example" ]]; then
                    msg_box "Missing Template" "$CONFIG_DIR/remotes.json.example is missing."
                elif confirm_box "Create Remotes" "Create $CONFIG_DIR/remotes.json from the example template?"; then
                    cp "$CONFIG_DIR/remotes.json.example" "$CONFIG_DIR/remotes.json"
                    msg_box "Created" "Created $CONFIG_DIR/remotes.json.\n\nEdit it with your SSH target and project path."
                fi
                ;;
            "Edit Config")
                if [[ ! -e "$CONFIG_DIR/remotes.json" ]]; then
                    msg_box "Missing Config" "Create $CONFIG_DIR/remotes.json first."
                else
                    "${EDITOR:-nano}" "$CONFIG_DIR/remotes.json"
                fi
                ;;
            "Back")
                return 0
                ;;
        esac
    done
}

choose_vm() {
    mapfile -t vm_items < <(list_vm_menu_items)
    local selected
    selected=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=18 menu_choose "VM Selection" "Choose a VM profile (type the first letter to jump)" "${vm_items[@]}") || return 1
    current_vm="$selected"
    return 0
}

main_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "QEMU ISO Lab" \
            "Choose where to work" \
            "Choose VM"    "Select a VM profile and open its workspace" \
            "Status"       "Show local VM state" \
            "Remote Hosts" "Configure saved SSH/SPICE remote hosts" \
            "Clean All"    "Remove artifacts for all configured VMs" \
            "Quit"         "Close the TUI") || {
                clear
                exit 0
            }

        case "$selected" in
            "Choose VM")
                if choose_vm; then
                    vm_menu_loop
                fi
                ;;
            "Status")
                run_action "Status"
                ;;
            "Remote Hosts")
                remote_hosts_menu_loop
                ;;
            "Clean All")
                run_action "Clean All"
                ;;
            "Quit")
                clear
                exit 0
                ;;
        esac
    done
}

if [[ "${VMTUI_TEST_MODE:-0}" != "1" ]]; then
    main_menu_loop
fi
