#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="${VMTUI_ROOT_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
CONFIG_DIR="${VMTUI_CONFIG_DIR:-$ROOT_DIR/vms}"
VMCTL="$ROOT_DIR/bin/vmctl"

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'error: missing command: %s\n' "$1" >&2
        exit 1
    fi
}

require_command dialog
require_command python3

if [[ ! -x "$VMCTL" ]]; then
    printf 'error: missing executable: %s\n' "$VMCTL" >&2
    exit 1
fi

if [[ ! -d "$CONFIG_DIR" ]]; then
    printf 'error: missing config directory: %s\n' "$CONFIG_DIR" >&2
    exit 1
fi

current_vm=""

menu_choose() {
    local title="$1"
    local prompt="$2"
    shift 2
    local output
    local status
    local height="${MENU_HEIGHT:-22}"
    local width="${MENU_WIDTH:-80}"
    local list_height="${MENU_LIST_HEIGHT:-12}"

    local -a dialog_args=(--clear --stdout --title "$title")
    if [[ "${MENU_NO_TAGS:-0}" == "1" ]]; then
        dialog_args+=(--no-tags)
    fi
    dialog_args+=(--menu "$prompt" "$height" "$width" "$list_height" "$@")
    output=$(dialog "${dialog_args[@]}") || status=$?
    status=${status:-0}
    if [[ $status -ne 0 ]]; then
        return 1
    fi
    printf '%s\n' "$output"
}

msg_box() {
    dialog --clear --title "$1" --msgbox "$2" 12 76
}

confirm_box() {
    dialog --clear --title "$1" --yesno "$2" 10 72
}

input_box() {
    local title="$1"
    local prompt="$2"
    local initial="${3:-}"
    local output
    local status

    output=$(dialog --clear --stdout --title "$title" --inputbox "$prompt" 12 72 "$initial") || status=$?
    status=${status:-0}
    if [[ $status -ne 0 ]]; then
        return 1
    fi
    printf '%s\n' "$output"
}

pause_box() {
    read -r -p "Press Enter to continue..." _
}

install_command_for() {
    case "$1" in
        remote-viewer)
            if command -v apt-get >/dev/null 2>&1; then
                printf '%s\n' "sudo apt-get install -y virt-viewer"
            elif command -v pacman >/dev/null 2>&1; then
                printf '%s\n' "sudo pacman -S --needed virt-viewer"
            elif command -v dnf >/dev/null 2>&1; then
                printf '%s\n' "sudo dnf install -y virt-viewer"
            else
                return 1
            fi
            ;;
        *)
            return 1
            ;;
    esac
}

ensure_optional_command() {
    local command_name="$1"
    local install_cmd

    if command -v "$command_name" >/dev/null 2>&1; then
        return 0
    fi

    install_cmd=$(install_command_for "$command_name") || {
        msg_box "Missing Command" "Missing command: $command_name\n\nInstall it manually and retry."
        return 1
    }

    if ! confirm_box "Install Dependency" "Missing command: $command_name\n\nInstall it now?\n\n$install_cmd"; then
        return 1
    fi

    clear
    printf '$ %s\n\n' "$install_cmd"
    if bash -lc "$install_cmd"; then
        printf '\nDependency installed.\n'
    else
        printf '\nDependency installation failed.\n'
        pause_box
        return 1
    fi
    pause_box

    command -v "$command_name" >/dev/null 2>&1
}

list_vm_menu_items() {
    python3 - "$ROOT_DIR" "$CONFIG_DIR" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])

from vmctl import config, state


def ellipsize(text: str, width: int) -> str:
    if len(text) <= width:
        return text
    if width <= 3:
        return text[:width]
    return text[: width - 3] + "..."


state.ROOT = Path(sys.argv[1])
state.CONFIG_DIR = Path(sys.argv[2])
for name, vm in sorted(config.load_config()["vms"].items()):
    label = vm.get("name", name)
    firmware = str(vm.get("firmware", {}).get("type", "?")).upper()
    memory = f"{vm.get('memory_mb', '?')} MB"
    cpus = vm.get("cpus", "?")
    cpu_label = f"{cpus} vCPU" if cpus == 1 else f"{cpus} vCPUs"
    description = "  ".join(
        [
            f"{ellipsize(label, 28):<28}",
            f"{firmware:>4}",
            f"{memory:>7}",
            f"{cpu_label:>7}",
        ]
    )
    print(name)
    print(description)
PY
}

list_video_menu_items() {
    python3 - "$ROOT_DIR" "$CONFIG_DIR" "$1" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])

from vmctl import config, state

state.ROOT = Path(sys.argv[1])
state.CONFIG_DIR = Path(sys.argv[2])
vm_name = sys.argv[3]
vm = config.load_config()["vms"][vm_name]
video = vm.get("video", {})
default = video.get("default", "")
variants = video.get("variants", {})
print("Default")
print(f"VM profile default ({default or 'none'})")
for name in sorted(variants):
    print(name)
    print(f"{name} video profile")
PY
}

vm_has_section() {
    python3 - "$ROOT_DIR" "$CONFIG_DIR" "$1" "$2" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])

from vmctl import config, state

state.ROOT = Path(sys.argv[1])
state.CONFIG_DIR = Path(sys.argv[2])
vm_name = sys.argv[3]
section = sys.argv[4]
vm = config.load_config()["vms"][vm_name]
raise SystemExit(0 if isinstance(vm.get(section), dict) else 1)
PY
}

vm_has_ssh_provision() {
    python3 - "$ROOT_DIR" "$CONFIG_DIR" "$1" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])

from vmctl import config, state

state.ROOT = Path(sys.argv[1])
state.CONFIG_DIR = Path(sys.argv[2])
vm_name = sys.argv[3]
vm = config.load_config()["vms"][vm_name]
ssh_cfg = vm.get("ssh_provision")
cloud_cfg = vm.get("cloud_init")
raise SystemExit(0 if isinstance(ssh_cfg, dict) or isinstance(cloud_cfg, dict) else 1)
PY
}

vm_has_unattended_install() {
    local vm_name="$1"
    vm_has_section "$vm_name" "autoinstall"
}

vm_disk_path() {
    python3 - "$ROOT_DIR" "$CONFIG_DIR" "$1" <<'PY'
import sys
from pathlib import Path

sys.path.insert(0, sys.argv[1])

from vmctl import config, state

state.ROOT = Path(sys.argv[1])
state.CONFIG_DIR = Path(sys.argv[2])
vm_name = sys.argv[3]
vm = config.load_config()["vms"][vm_name]
disk = vm.get("disk", {})
path = disk.get("path", "") if isinstance(disk, dict) else ""
print(path or "")
PY
}

vm_status_summary() {
    local vm_name="$1"
    if vm_is_running_headless "$vm_name"; then
        printf '%s\n' "running (headless)"
        return
    fi
    local disk
    disk=$(vm_disk_path "$vm_name")
    if [[ -n "$disk" ]]; then
        local abs="$disk"
        if [[ "$abs" != /* ]]; then
            abs="$ROOT_DIR/$abs"
        fi
        if [[ -f "$abs" ]]; then
            printf '%s\n' "installed, stopped"
            return
        fi
    fi
    printf '%s\n' "not installed"
}

list_remote_menu_items() {
    python3 - "$CONFIG_DIR" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
path = config_dir / "remotes.json"
if not path.exists():
    raise SystemExit(0)
data = json.loads(path.read_text(encoding="utf-8"))
remotes = data.get("remotes", {})
if not isinstance(remotes, dict):
    raise SystemExit(0)
for name, remote in sorted(remotes.items()):
    if not isinstance(remote, dict):
        continue
    label = remote.get("label", name)
    target = remote.get("ssh_target", "")
    project = remote.get("project_dir", "")
    ports = f"{remote.get('local_spice_port', 5930)}->{remote.get('remote_spice_port', 5930)}"
    print(name)
    print(f"{label}  {target}  {ports}  {project}")
PY
}

remote_field() {
    python3 - "$CONFIG_DIR" "$1" "$2" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
remote_name = sys.argv[2]
field = sys.argv[3]
path = config_dir / "remotes.json"
data = json.loads(path.read_text(encoding="utf-8"))
remote = data.get("remotes", {}).get(remote_name)
if not isinstance(remote, dict):
    raise SystemExit(f"unknown remote: {remote_name}")
value = remote.get(field, "")
print(value)
PY
}

vm_is_running_headless() {
    python3 - "$VMCTL" "$1" <<'PY'
import json
import subprocess
import sys

vmctl = sys.argv[1]
vm_name = sys.argv[2]
result = subprocess.run(
    [vmctl, "status", "--json"],
    check=True,
    capture_output=True,
    text=True,
)
for row in json.loads(result.stdout):
    if row.get("profile") != vm_name:
        continue
    runtime = str(row.get("runtime") or "")
    raise SystemExit(0 if runtime.startswith(("tracked:", "hostfwd:", "running:")) else 1)
raise SystemExit(1)
PY
}

emit_section() {
    local name="$1"
    printf '__sep_%s\n━━━ %s %s\n' "$name" "$name" "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

emit_action() {
    local tag="$1"
    local desc="$2"
    printf '%s\n  %-27s %s\n' "$tag" "$tag" "$desc"
}

list_vm_menu_items_unified() {
    local vm_name="$1"
    local running=0
    local installed=0
    local has_ssh=0
    local has_autoinstall=0
    local has_archinstall=0
    local has_preseed=0
    local has_kickstart=0
    local has_cloud_init=0

    vm_is_running_headless "$vm_name" && running=1
    local disk
    disk=$(vm_disk_path "$vm_name")
    if [[ -n "$disk" ]]; then
        local abs="$disk"
        [[ "$abs" != /* ]] && abs="$ROOT_DIR/$abs"
        [[ -f "$abs" ]] && installed=1
    fi
    vm_has_ssh_provision "$vm_name" && has_ssh=1
    vm_has_unattended_install "$vm_name" && has_autoinstall=1
    vm_has_section "$vm_name" "archinstall_config" && has_archinstall=1
    vm_has_section "$vm_name" "preseed_config" && has_preseed=1
    vm_has_section "$vm_name" "kickstart_config" && has_kickstart=1
    vm_has_section "$vm_name" "cloud_init" && has_cloud_init=1

    emit_section "INSTALL"
    if [[ $has_archinstall -eq 1 ]]; then
        emit_action "Arch Bootstrap" "Fully automated Arch install + post-install"
        emit_action "Arch Install (Interactive)" "Boot live ISO with pre-built archinstall config"
    elif [[ $has_preseed -eq 1 ]]; then
        emit_action "Debian Preseed Bootstrap" "Fully automated Debian install + post-install"
        emit_action "Guided Provision" "Fetch ISO, prepare artifacts, boot installer"
    elif [[ $has_kickstart -eq 1 ]]; then
        emit_action "Kickstart Bootstrap" "Fully automated AlmaLinux/RHEL install + post-install"
        emit_action "Guided Provision" "Fetch ISO, prepare artifacts, boot installer"
    elif [[ $has_autoinstall -eq 1 && $has_ssh -eq 1 ]]; then
        emit_action "Full Bootstrap" "Unattended install, first boot, and post-install"
        emit_action "Unattended Install" "Run the configured Ubuntu autoinstall flow"
        emit_action "Cloud-Init Flow" "Manual installer with first-boot handoff"
    elif [[ $has_autoinstall -eq 1 ]]; then
        emit_action "Unattended Install" "Run the configured Ubuntu autoinstall flow"
        emit_action "Guided Provision" "Fetch ISO, prepare artifacts, boot installer"
    elif [[ $has_cloud_init -eq 1 ]]; then
        emit_action "Cloud-Init Flow" "Manual installer with first-boot handoff"
        emit_action "Seeded Installer" "Boot installer with a generated cloud-init seed"
        emit_action "Guided Provision" "Fetch ISO, prepare artifacts, boot installer"
    else
        emit_action "Guided Provision" "Fetch ISO, prepare artifacts, boot installer"
        emit_action "Installer Only" "Boot the installer without preparation"
    fi

    emit_section "RUN"
    if [[ $installed -eq 1 ]]; then
        emit_action "Boot Desktop" "Start the installed VM with display"
        emit_action "Boot Headless" "Start the installed VM in the background"
    else
        emit_action "Boot Desktop" "(no disk yet: run an install action first)"
        emit_action "Boot Headless" "(no disk yet: run an install action first)"
    fi
    if [[ $running -eq 1 ]]; then
        emit_action "Stop VM" "Stop the tracked background process"
    else
        emit_action "Stop VM" "(VM not running)"
    fi
    if [[ $has_ssh -eq 1 ]]; then
        emit_action "SSH Console" "Open a shell inside the VM"
    else
        emit_action "SSH Console" "(no ssh_provision in profile)"
    fi
    if [[ $has_cloud_init -eq 1 ]]; then
        emit_action "First Boot" "Start the VM with cloud-init enabled"
    fi

    emit_section "MAINTENANCE"
    if [[ $has_ssh -eq 1 ]]; then
        emit_action "Post-Install" "Run configured SSH provisioning tasks"
    else
        emit_action "Post-Install" "(no ssh_provision in profile)"
    fi
    emit_action "Boot Check" "Run a headless smoke test"
    emit_action "Fetch ISO" "Download or validate the configured ISO"
    emit_action "Prepare VM" "Create disk and firmware artifacts"
    emit_action "Clean VM" "Remove artifacts for this VM"
    emit_action "Delete ISO" "Remove this VM's cached ISO"
    emit_action "Profile Details" "Review this VM configuration"

    emit_section "ADVANCED"
    emit_action "Flash Empty Disk" "Write the VM disk to an empty physical device"
    emit_action "Force Flash" "Wipe and write a non-empty physical device"
    emit_action "Import Disk" "Read a physical device into the VM image"

    emit_section "OTHER"
    emit_action "Remote SPICE" "Start this VM on a remote host and open SPICE viewer"
    emit_action "Back" "Return to main menu"
}

is_na_action() {
    local tag="$1"
    local vm_name="$2"
    case "$tag" in
        "Boot Desktop"|"Boot Headless")
            local disk
            disk=$(vm_disk_path "$vm_name")
            if [[ -z "$disk" ]]; then
                return 0
            fi
            local abs="$disk"
            [[ "$abs" != /* ]] && abs="$ROOT_DIR/$abs"
            [[ ! -f "$abs" ]]
            ;;
        "Stop VM")
            ! vm_is_running_headless "$vm_name"
            ;;
        "SSH Console"|"Post-Install")
            ! vm_has_ssh_provision "$vm_name"
            ;;
        *)
            return 1
            ;;
    esac
}

msg_na_action() {
    local tag="$1"
    local vm_name="$2"
    case "$tag" in
        "Boot Desktop"|"Boot Headless")
            msg_box "VM Not Installed" "VM '$vm_name' has no installed disk yet.\n\nRun an INSTALL action first (Bootstrap, Guided Provision, or Unattended Install)."
            ;;
        "Stop VM")
            msg_box "VM Not Running" "VM '$vm_name' is not currently tracked as running headless.\n\nStart it first with 'Boot Desktop' or 'Boot Headless'."
            ;;
        "SSH Console"|"Post-Install")
            msg_box "SSH Not Configured" "VM '$vm_name' has no 'ssh_provision' section in its profile.\n\nAdd one to vms/profiles/*.json to enable SSH actions."
            ;;
        *)
            msg_box "Not Available" "Action '$tag' is not available for VM '$vm_name'."
            ;;
    esac
}

list_empty_device_menu_items() {
    python3 - "$VMCTL" <<'PY'
import subprocess
import sys

vmctl = sys.argv[1]
result = subprocess.run(
    [vmctl, "list-empty-devices"],
    check=True,
    capture_output=True,
    text=True,
)
for line in result.stdout.splitlines():
    if not line.strip():
        continue
    path, size, model = (line.split("\t", 2) + ["-", "-"])[:3]
    print(path)
    print(f"{size:>10}  {model}")
PY
}

