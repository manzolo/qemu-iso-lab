#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG_DIR="$ROOT_DIR/vms"
VMCTL="$ROOT_DIR/bin/vmctl"

require_command() {
    if ! command -v "$1" >/dev/null 2>&1; then
        printf 'error: missing command: %s\n' "$1" >&2
        exit 1
    fi
}

require_command dialog
require_command python3

if [[ ! -x "$VMCTL" ]]; then
    printf 'error: missing executable: %s\n' "$VMCTL" >&2
    exit 1
fi

if [[ ! -d "$CONFIG_DIR" ]]; then
    printf 'error: missing config directory: %s\n' "$CONFIG_DIR" >&2
    exit 1
fi

current_vm=""

menu_choose() {
    local title="$1"
    local prompt="$2"
    shift 2
    local output
    local status
    local height="${MENU_HEIGHT:-22}"
    local width="${MENU_WIDTH:-80}"
    local list_height="${MENU_LIST_HEIGHT:-12}"

    output=$(dialog --clear --stdout --title "$title" --menu "$prompt" "$height" "$width" "$list_height" "$@") || status=$?
    status=${status:-0}
    if [[ $status -ne 0 ]]; then
        return 1
    fi
    printf '%s\n' "$output"
}

msg_box() {
    dialog --clear --title "$1" --msgbox "$2" 10 72
}

confirm_box() {
    dialog --clear --title "$1" --yesno "$2" 10 72
}

input_box() {
    local title="$1"
    local prompt="$2"
    local initial="${3:-}"
    local output
    local status

    output=$(dialog --clear --stdout --title "$title" --inputbox "$prompt" 12 72 "$initial") || status=$?
    status=${status:-0}
    if [[ $status -ne 0 ]]; then
        return 1
    fi
    printf '%s\n' "$output"
}

pause_box() {
    read -r -p "Press Enter to continue..." _
}

list_vm_menu_items() {
    python3 - "$CONFIG_DIR" <<'PY'
import json
import sys
from pathlib import Path


def ellipsize(text: str, width: int) -> str:
    if len(text) <= width:
        return text
    if width <= 3:
        return text[:width]
    return text[: width - 3] + "..."


config_dir = Path(sys.argv[1])
data = {"catalog": {}, "vms": {}}
for profile_path in sorted((config_dir / "profiles").glob("*.json")):
    profile_data = json.loads(profile_path.read_text(encoding="utf-8"))
    data["vms"].update(profile_data["vms"])
for name, vm in sorted(data["vms"].items()):
    label = vm.get("name", name)
    firmware = str(vm.get("firmware", {}).get("type", "?")).upper()
    memory = f"{vm.get('memory_mb', '?')} MB"
    cpus = vm.get("cpus", "?")
    cpu_label = f"{cpus} vCPU" if cpus == 1 else f"{cpus} vCPUs"
    description = "  ".join(
        [
            f"{ellipsize(label, 28):<28}",
            f"{firmware:>4}",
            f"{memory:>7}",
            f"{cpu_label:>7}",
        ]
    )
    print(name)
    print(description)
PY
}

list_video_menu_items() {
    python3 - "$CONFIG_DIR" "$1" <<'PY'
import json
import sys
from pathlib import Path

config_dir = Path(sys.argv[1])
vm_name = sys.argv[2]
data = {"vms": {}}
for profile_path in sorted((config_dir / "profiles").glob("*.json")):
    profile_data = json.loads(profile_path.read_text(encoding="utf-8"))
    data["vms"].update(profile_data["vms"])
vm = data["vms"][vm_name]
video = vm.get("video", {})
default = video.get("default", "")
variants = video.get("variants", {})
print("__default__")
print(f"Use vm default ({default or 'none'})")
for name in sorted(variants):
    print(name)
    print(f"Video profile {name}")
PY
}

list_empty_device_menu_items() {
    python3 - "$VMCTL" <<'PY'
import subprocess
import sys

vmctl = sys.argv[1]
result = subprocess.run(
    [vmctl, "list-empty-devices"],
    check=True,
    capture_output=True,
    text=True,
)
for line in result.stdout.splitlines():
    if not line.strip():
        continue
    path, size, model = (line.split("\t", 2) + ["-", "-"])[:3]
    print(path)
    print(f"{size:>10}  {model}")
PY
}

list_target_device_menu_items() {
    python3 - "$VMCTL" <<'PY'
import subprocess
import sys

vmctl = sys.argv[1]
result = subprocess.run(
    [vmctl, "list-target-devices"],
    check=True,
    capture_output=True,
    text=True,
)
for line in result.stdout.splitlines():
    if not line.strip():
        continue
    path, size, model = (line.split("\t", 2) + ["-", "-"])[:3]
    print(path)
    print(f"{size:>10}  {model}")
PY
}

run_vmctl() {
    clear
    printf 'Selected VM: %s\n' "$current_vm"
    printf '$ %q' "$VMCTL"
    for arg in "$@"; do
        printf ' %q' "$arg"
    done
    printf '\n\n'

    if "$VMCTL" "$@"; then
        printf '\nCommand completed successfully.\n'
    else
        local status=$?
        printf '\nCommand failed with exit code %s.\n' "$status"
    fi
    pause_box
}

choose_vm() {
    mapfile -t vm_items < <(list_vm_menu_items)
    local selected
    selected=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=14 menu_choose "VM Selection" "Choose a VM profile" "${vm_items[@]}") || return 1
    current_vm="$selected"
    return 0
}

choose_video() {
    mapfile -t video_items < <(list_video_menu_items "$current_vm")
    local selected
    selected=$(menu_choose "Video Profile" "Choose a video profile for $current_vm" "${video_items[@]}") || return 1
    if [[ "$selected" == "__default__" ]]; then
        printf '\n'
    else
        printf '%s\n' "$selected"
    fi
}

run_action() {
    local action="$1"
    case "$action" in
        show)
            run_vmctl show "$current_vm"
            ;;
        provision)
            local video
            video=$(choose_video) || return 0
            if confirm_box "Confirm Provision" "Guided install for VM '$current_vm'?\n\nThis will:\n- download the ISO if missing\n- create disk and firmware artifacts if missing\n- start the installer"; then
                if [[ -n "$video" ]]; then
                    run_vmctl provision "$current_vm" --video "$video"
                else
                    run_vmctl provision "$current_vm"
                fi
            fi
            ;;
        fetch-iso)
            run_vmctl fetch-iso "$current_vm"
            ;;
        prep)
            run_vmctl prep "$current_vm"
            ;;
        install)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl install "$current_vm" --video "$video"
            else
                run_vmctl install "$current_vm"
            fi
            ;;
        start)
            local video
            video=$(choose_video) || return 0
            if [[ -n "$video" ]]; then
                run_vmctl start "$current_vm" --video "$video"
            else
                run_vmctl start "$current_vm"
            fi
            ;;
        boot-check)
            run_vmctl boot-check "$current_vm"
            ;;
        clean)
            if confirm_box "Confirm Clean" "Remove artifacts for VM '$current_vm'?"; then
                run_vmctl clean "$current_vm"
            fi
            ;;
        flash)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_empty_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Empty Devices" "No empty whole-disk devices are currently eligible for flashing, or elevated privileges are required to inspect them."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Flash Device" "Choose an empty target disk" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Operation" "Write VM '$current_vm' to physical device '$selected_device'?\n\nThis will overwrite the entire disk."; then
                return 0
            fi
            typed_device=$(input_box "Type Device Path" "Type the device path again to confirm destructive flash:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Flash cancelled."
                return 0
            fi
            run_vmctl flash "$current_vm" --device "$selected_device" --confirm-device "$typed_device"
            ;;
        flash-force)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_target_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Eligible Devices" "No non-root whole-disk devices are currently available for force flashing."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Force Flash Device" "Choose a target disk to wipe and overwrite" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Force Flash" "Force-write VM '$current_vm' to '$selected_device'?\n\nThis will wipe existing partition tables and signatures before writing."; then
                return 0
            fi
            typed_device=$(input_box "Type WIPE Device" "Type the device path again to confirm forced destructive flash:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Force flash cancelled."
                return 0
            fi
            run_vmctl flash "$current_vm" --device "$selected_device" --confirm-device "$typed_device" --force-target
            ;;
        import-device)
            local selected_device
            local typed_device
            mapfile -t device_items < <(list_target_device_menu_items)
            if [[ ${#device_items[@]} -eq 0 ]]; then
                msg_box "No Eligible Devices" "No non-root whole-disk devices are currently available for import."
                return 0
            fi
            selected_device=$(MENU_WIDTH=96 MENU_LIST_HEIGHT=10 menu_choose "Import Device" "Choose a physical disk to read into the VM image" "${device_items[@]}") || return 0
            if ! confirm_box "Dangerous Import" "Import physical device '$selected_device' into VM '$current_vm'?\n\nThis will overwrite the VM disk image."; then
                return 0
            fi
            typed_device=$(input_box "Type Source Device" "Type the device path again to confirm VM disk overwrite:" "$selected_device") || return 0
            if [[ "$typed_device" != "$selected_device" ]]; then
                msg_box "Confirmation Failed" "Typed device path does not match. Import cancelled."
                return 0
            fi
            run_vmctl import-device "$current_vm" --device "$selected_device" --confirm-device "$typed_device"
            ;;
        clean-all)
            if confirm_box "Confirm Clean All" "Remove artifacts for all configured VMs?"; then
                run_vmctl clean --all
            fi
            ;;
        advanced)
            advanced_menu_loop
            ;;
        back)
            return 1
            ;;
        choose-vm)
            choose_vm || return 1
            ;;
        quit)
            clear
            exit 0
            ;;
    esac
}

vm_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "VM Actions" \
            "Current VM: $current_vm" \
            provision "Guided install: fetch, prep, boot installer" \
            show "Show VM profile" \
            fetch-iso "Download ISO if missing" \
            prep "Prepare disk and firmware artifacts" \
            install "Boot installer" \
            start "Boot installed VM" \
            boot-check "Run headless boot smoke check" \
            clean "Clean current VM artifacts" \
            back "Torna al menu") || return 0
        run_action "$selected" || return 0
    done
}

advanced_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "Advanced Actions" \
            "Current VM: $current_vm" \
            flash "Write VM disk to an empty physical device" \
            flash-force "Force-write VM disk to a non-empty physical device" \
            import-device "Read a physical device into the VM disk image" \
            back "Back") || return 0
        run_action "$selected" || return 0
    done
}

main_menu_loop() {
    while true; do
        local selected
        selected=$(menu_choose \
            "QEMU ISO Lab" \
            "Main menu" \
            choose-vm "Seleziona una VM" \
            advanced "Azioni avanzate" \
            clean-all "Pulisci gli artifact di tutte le VM" \
            quit "Esci") || {
                clear
                exit 0
            }

        case "$selected" in
            choose-vm)
                if choose_vm; then
                    vm_menu_loop
                fi
                ;;
            advanced)
                if [[ -z "$current_vm" ]]; then
                    if choose_vm; then
                        advanced_menu_loop
                    fi
                else
                    advanced_menu_loop
                fi
                ;;
            clean-all|quit)
                run_action "$selected"
                ;;
        esac
    done
}

main_menu_loop
